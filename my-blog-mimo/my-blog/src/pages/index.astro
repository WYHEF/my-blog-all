---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import { getAllPosts } from '@/utils/post';
import { SITE_CONFIG } from '@/config';

const posts = await getAllPosts();
const recentPosts = posts.slice(0, SITE_CONFIG.postsPerPage);
---

<BaseLayout title={SITE_CONFIG.title} description={SITE_CONFIG.description}>
  <div class="container">
    <section class="hero">
      <h1 class="hero-title">欢迎阅读</h1>
      <p class="hero-description">
        这里记录了我的技术探索、学习笔记和旅行见闻。
        <br>
        请从左侧选择文章，或通过上方导航切换分类。
      </p>
    </section>
    
    <section class="posts">
      <h2 class="section-title">最新更新</h2>
      <div class="posts-list">
        {recentPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .hero {
    padding: var(--spacing-xl) 0;
    margin-bottom: var(--spacing-xl);
    border-bottom: none;
    position: relative;
    background: var(--gradient-hero);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl) var(--spacing-xl) var(--spacing-lg);
    margin: 0 calc(-1 * var(--spacing-lg)) var(--spacing-xl);
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: var(--spacing-xl);
    right: var(--spacing-xl);
    height: 1px;
    background: var(--gradient-border);
    opacity: 0.3;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 500;
    margin-bottom: var(--spacing-sm);
    letter-spacing: -0.03em;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    font-style: italic;
    line-height: 1.5;
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    margin-bottom: var(--spacing-lg);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .posts-list > :global(*) {
    animation: fadeSlideIn 0.4s ease-out both;
  }

  .posts-list > :global(*:nth-child(1)) { animation-delay: 0.05s; }
  .posts-list > :global(*:nth-child(2)) { animation-delay: 0.1s; }
  .posts-list > :global(*:nth-child(3)) { animation-delay: 0.15s; }
  .posts-list > :global(*:nth-child(4)) { animation-delay: 0.2s; }
  .posts-list > :global(*:nth-child(5)) { animation-delay: 0.25s; }
  .posts-list > :global(*:nth-child(6)) { animation-delay: 0.3s; }
  .posts-list > :global(*:nth-child(7)) { animation-delay: 0.35s; }
  .posts-list > :global(*:nth-child(8)) { animation-delay: 0.4s; }
  .posts-list > :global(*:nth-child(9)) { animation-delay: 0.45s; }
  .posts-list > :global(*:nth-child(10)) { animation-delay: 0.5s; }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .view-all {
    margin-top: var(--spacing-lg);
  }

  .btn-link {
    display: inline-block;
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
    border-bottom: none;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.5rem 1.2rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    transition: all var(--transition-normal);
  }

  .btn-link:hover {
    border-color: var(--color-primary);
    background-color: var(--color-primary-light);
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--spacing-lg);
      margin: 0 calc(-1 * var(--spacing-md)) var(--spacing-xl);
      border-radius: var(--radius-lg);
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-description {
      font-size: 1.15rem;
    }
  }
</style>

