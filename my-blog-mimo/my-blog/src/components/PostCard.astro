---
import type { Post } from '@/utils/post';
import { formatDate } from '@/utils/post';
import { SITE_CONFIG } from '@/config';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, pubDate, category, tags } = post.data;
const categoryConfig = SITE_CONFIG.categories[category];
---

<article class="post-item">
  <div class="post-meta">
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    <span class="separator">/</span>
    <a href={`/category/${category}`} class="category-link">{categoryConfig.displayName}</a>
  </div>
  
  <h2 class="post-title">
    <a href={`/blog/${post.slug}`}>{title}</a>
  </h2>
  
  <p class="post-description">{description}</p>
  
  {tags && tags.length > 0 && (
    <div class="post-tags">
      {tags.map(tag => (
        <a href={`/tags/${tag}`} class="tag">#{tag}</a>
      ))}
    </div>
  )}
</article>

<style>
  .post-item {
    padding: var(--spacing-lg);
    margin-bottom: var(--spacing-md);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xs);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal), border-color var(--transition-normal);
  }

  .post-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-border);
  }

  .post-item:last-child {
    margin-bottom: 0;
  }

  .post-meta {
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    margin-bottom: var(--spacing-xs);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .separator {
    margin: 0 0.5em;
    opacity: 0.4;
  }

  .category-link {
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    font-weight: 600;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .category-link:hover {
    color: var(--color-primary-hover);
    border-bottom-color: var(--color-primary);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    margin-bottom: var(--spacing-xs);
    line-height: 1.3;
    font-weight: 600;
  }

  .post-title a {
    color: var(--color-text);
    text-decoration: none;
    border-bottom: none;
    transition: color var(--transition-fast);
  }

  .post-title a:hover {
    background: var(--gradient-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .post-description {
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: var(--spacing-sm);
    font-size: 0.95rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-bottom: none;
    background-color: var(--color-bg-secondary);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-light);
    transition: all var(--transition-fast);
  }

  .tag:hover {
    color: var(--color-primary);
    background-color: var(--color-primary-light);
    border-color: var(--color-primary);
    transform: translateY(-1px);
  }
</style>

