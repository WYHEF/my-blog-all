---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/config';

const videos = [
  { bvid: 'BV1wXQHYBEtt', title: '视频教程 1' },
  { bvid: 'BV1FJKezFETE', title: '视频教程 2' },
  { bvid: 'BV1GQKYzEEfs', title: '视频教程 3' },
  { bvid: 'BV1yqrNBoEh3', title: '视频教程 4' },
  { bvid: 'BV1m8rNBaEaX', title: '视频教程 5' },
  { bvid: 'BV1M8rNBYEj2', title: '视频教程 6' },
  { bvid: 'BV1ubrNBPEg3', title: '视频教程 7' },
  { bvid: 'BV1UbrNBAEGD', title: '视频教程 8' },
  { bvid: 'BV1UbrNBAE3n', title: '视频教程 9' },
  { bvid: 'BV12YrNB8EW8', title: '视频教程 10' },
  { bvid: 'BV1xYrNBhEZe', title: '视频教程 11' },
  { bvid: 'BV14YrNBhEqb', title: '视频教程 12' },
];
---

<BaseLayout
  title={`视频教程 - ${SITE_CONFIG.title}`}
  description={`${SITE_CONFIG.author}的B站视频教程合集`}
>
  <div class="page-container">
    <header class="page-header">
      <div class="section-label">| VIDEOS</div>
      <h1 class="page-title">视频教程</h1>
      <p class="page-description">
        我在 B 站发布的教程视频合集，欢迎
        <a href={SITE_CONFIG.bilibili} target="_blank" rel="noopener noreferrer">关注我的 B 站频道</a>
        获取更多内容。
      </p>
    </header>

    <div class="videos-grid">
      {videos.map((video, index) => (
        <div class="video-card">
          <div class="video-wrapper">
            <iframe
              src={`//player.bilibili.com/player.html?bvid=${video.bvid}&page=1`}
              scrolling="no"
              border="0"
              frameborder="no"
              framespacing="0"
              allowfullscreen="true"
              loading="lazy"
            ></iframe>
          </div>
          <div class="video-info">
            <span class="video-index">#{index + 1}</span>
            <a
              href={`https://www.bilibili.com/video/${video.bvid}`}
              target="_blank"
              rel="noopener noreferrer"
              class="video-link"
            >
              在 B 站观看
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  .page-header {
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--spacing-sm);
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: var(--spacing-sm);
  }

  .page-description {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
  }

  .page-description a {
    color: var(--color-primary);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .page-description a:hover {
    border-bottom-color: var(--color-primary);
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
  }

  .video-card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .video-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 60%;
    overflow: hidden;
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-sm) var(--spacing-md);
  }

  .video-index {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .video-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-bottom: none;
    transition: color 0.2s ease;
  }

  .video-link:hover {
    color: var(--color-text);
    border-bottom: none;
  }

  @media (max-width: 768px) {
    .page-container {
      padding: var(--spacing-lg) var(--spacing-md);
    }

    .page-title {
      font-size: 2rem;
    }

    .videos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
