---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import Search from '@components/Search.astro';
import ParticleField from '@components/ParticleField.astro';
import ScrollReveal from '@components/ScrollReveal.astro';
import { getAllPosts } from '@/utils/post';
import { SITE_CONFIG } from '@/config';

const posts = await getAllPosts();
const recentPosts = posts.slice(0, 6);

const categories = [
  { key: 'tech', icon: '⚡', title: '技术', desc: '技术文章和教程', color: '#6366f1' },
  { key: 'notes', icon: '📝', title: '笔记', desc: '学习笔记和总结', color: '#8b5cf6' },
  { key: 'travel', icon: '✈️', title: '游记', desc: '旅行见闻', color: '#3b82f6' },
];
---

<BaseLayout title={SITE_CONFIG.title} description={SITE_CONFIG.description}>
  <ParticleField />
  <ScrollReveal />

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <!-- 动态光晕 -->
      <div class="hero-glow glow-1"></div>
      <div class="hero-glow glow-2"></div>
      <div class="hero-glow glow-3"></div>
      <!-- 网格线 -->
      <div class="hero-grid"></div>
    </div>

    <div class="hero-content">
      <!-- 动态标题 - 光效追踪 -->
      <div class="hero-title-wrapper">
        <h1 class="hero-title" data-text="WYHEF">WYHEF</h1>
        <div class="hero-title-glow"></div>
      </div>

      <p class="hero-subtitle" data-reveal>
        记录技术、学习与生活
      </p>

      <!-- 动态搜索框 -->
      <div class="hero-search-wrapper" data-reveal data-reveal-delay="2">
        <div class="search-glow"></div>
        <Search />
      </div>

      <div class="hero-cta" data-reveal data-reveal-delay="3">
        <a href="/about" class="cta-btn primary">
          <span>了解更多</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/category/tech" class="cta-btn secondary">浏览文章</a>
      </div>

      <!-- 向下滚动指示 -->
      <div class="scroll-indicator" data-reveal data-reveal-delay="4">
        <div class="scroll-line"></div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section class="products-section">
    <div class="section-label" data-reveal>| CONTENT</div>
    <h2 class="section-heading" data-reveal>探索内容</h2>

    <div class="products-grid">
      {categories.map((cat, i) => (
        <a href={`/category/${cat.key}`} class="product-card" data-reveal data-reveal-delay={String(i + 1)}>
          <div class="product-glow" style={`--glow-color: ${cat.color};`}></div>
          <div class="product-preview">
            <div class="product-preview-grid">
              {Array.from({length: 6}).map(() => (
                <div class="preview-dot" style={`animation-delay: ${Math.random() * 2}s;`}></div>
              ))}
            </div>
          </div>
          <div class="product-icon">{cat.icon}</div>
          <h3 class="product-title">{cat.title}</h3>
          <p class="product-desc">{cat.desc}</p>
          <span class="product-link">
            查看更多
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- 大标题动画区 -->
  <section class="showcase-section">
    <div class="showcase-bg">
      <div class="showcase-orb"></div>
    </div>
    <div class="showcase-content">
      <h2 class="showcase-text" data-reveal-text>Understand</h2>
      <h2 class="showcase-text highlight" data-reveal-text>The Universe</h2>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="stats-section">
    <div class="stats-grid">
      <div class="stat-item" data-reveal data-reveal-delay="1">
        <span class="stat-number" data-counter={posts.length}>0</span>
        <span class="stat-label">篇文章</span>
      </div>
      <div class="stat-item" data-reveal data-reveal-delay="2">
        <span class="stat-number" data-counter={3}>0</span>
        <span class="stat-label">个分类</span>
      </div>
      <div class="stat-item" data-reveal data-reveal-delay="3">
        <span class="stat-number">{SITE_CONFIG.author}</span>
        <span class="stat-label">作者</span>
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="posts-section">
    <div class="posts-header" data-reveal>
      <div>
        <div class="section-label">| BLOG</div>
        <h2 class="section-heading">最新文章</h2>
      </div>
      <a href="/category/tech" class="explore-link">
        EXPLORE MORE
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="posts-list">
      {recentPosts.map((post, i) => (
        <div data-reveal data-reveal-delay={String(Math.min(i + 1, 3))}>
          <PostCard post={post} />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* ========== Hero Section ========== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: var(--spacing-xl);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  /* 动态光晕 */
  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    animation: floatGlow 10s ease-in-out infinite;
  }

  .glow-1 {
    top: 30%;
    left: 50%;
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(99, 102, 241, 0.2) 0%, transparent 70%);
    transform: translate(-50%, -50%);
    animation-delay: 0s;
  }

  .glow-2 {
    top: 40%;
    right: 15%;
    width: 400px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(139, 92, 246, 0.15) 0%, transparent 70%);
    animation-delay: -3s;
  }

  .glow-3 {
    bottom: 20%;
    left: 30%;
    width: 500px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
    animation-delay: -6s;
  }

  @keyframes floatGlow {
    0%, 100% { transform: translate(-50%, -50%) scale(1) rotate(0deg); }
    33% { transform: translate(-40%, -60%) scale(1.1) rotate(5deg); }
    66% { transform: translate(-60%, -40%) scale(0.95) rotate(-3deg); }
  }

  /* 网格背景 */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99, 102, 241, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99, 102, 241, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 900px;
  }

  /* 动态标题 */
  .hero-title-wrapper {
    position: relative;
    margin-bottom: var(--spacing-md);
  }

  .hero-title {
    font-size: clamp(5rem, 15vw, 10rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 0.9;
    background: linear-gradient(135deg, #ffffff 0%, #c7d2fe 40%, #6366f1 70%, #4f46e5 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    position: relative;
    animation: titlePulse 4s ease-in-out infinite;
  }

  @keyframes titlePulse {
    0%, 100% { filter: brightness(1); }
    50% { filter: brightness(1.15); }
  }

  .hero-title-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.3) 0%, transparent 60%);
    filter: blur(40px);
    opacity: 0.5;
    animation: glowPulse 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes glowPulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.05); }
  }

  .hero-subtitle {
    font-size: 1.3rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-xl);
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  /* 搜索框发光效果 */
  .hero-search-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
    margin-bottom: var(--spacing-lg);
  }

  .search-glow {
    position: absolute;
    inset: -2px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.3), rgba(59, 130, 246, 0.2), rgba(139, 92, 246, 0.3));
    border-radius: var(--radius-lg);
    filter: blur(8px);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }

  .hero-search-wrapper:focus-within .search-glow {
    opacity: 1;
    animation: searchGlow 2s ease-in-out infinite;
  }

  @keyframes searchGlow {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 0.8; }
  }

  .hero-cta {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    border-bottom: none;
    position: relative;
    overflow: hidden;
  }

  .cta-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .cta-btn:hover::before {
    opacity: 1;
  }

  .cta-btn.primary {
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  .cta-btn.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.3);
    border-bottom: none;
  }

  .cta-btn.secondary {
    background-color: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .cta-btn.secondary:hover {
    border-color: var(--color-text-secondary);
    transform: translateY(-2px);
    border-bottom: 1px solid var(--color-text-secondary);
  }

  /* 滚动指示器 */
  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--color-text-secondary), transparent);
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: scaleY(1); opacity: 1; }
    50% { transform: scaleY(0.5); opacity: 0.3; }
  }

  /* ========== Products Section ========== */
  .products-section {
    padding: var(--spacing-xl) var(--spacing-lg);
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--spacing-sm);
  }

  .section-heading {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: var(--spacing-xl);
    color: var(--color-text);
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
  }

  .product-card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .product-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, var(--glow-color) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .product-card:hover .product-glow {
    opacity: 0.08;
  }

  .product-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-4px);
    border-bottom: 1px solid var(--color-border-hover);
  }

  .product-preview {
    height: 120px;
    margin-bottom: var(--spacing-md);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-bg-card-hover), var(--color-bg));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .product-preview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    padding: 16px;
  }

  .preview-dot {
    width: 8px;
    height: 8px;
    background: var(--glow-color);
    border-radius: 50%;
    opacity: 0.3;
    animation: dotPulse 3s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { opacity: 0.2; transform: scale(0.8); }
    50% { opacity: 0.6; transform: scale(1.2); }
  }

  .product-icon {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-sm);
  }

  .product-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--spacing-xs);
  }

  .product-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: var(--spacing-md);
  }

  .product-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    border-bottom: none;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .product-card:hover .product-link {
    color: var(--color-text);
  }

  /* ========== Showcase Section ========== */
  .showcase-section {
    position: relative;
    padding: calc(var(--spacing-xl) * 2) var(--spacing-lg);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
  }

  .showcase-bg {
    position: absolute;
    inset: 0;
  }

  .showcase-orb {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, rgba(59, 130, 246, 0.05) 40%, transparent 70%);
    border-radius: 50%;
    animation: orbFloat 8s ease-in-out infinite;
  }

  @keyframes orbFloat {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -50%) scale(1.2); }
  }

  .showcase-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .showcase-text {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .showcase-text.highlight {
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    opacity: 1;
  }

  /* ========== Stats Section ========== */
  .stats-section {
    padding: var(--spacing-xl) var(--spacing-lg);
    max-width: 1200px;
    margin: 0 auto;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xl);
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.03em;
    margin-bottom: var(--spacing-xs);
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ========== Posts Section ========== */
  .posts-section {
    padding: var(--spacing-xl) var(--spacing-lg);
    max-width: 1200px;
    margin: 0 auto;
  }

  .posts-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--spacing-lg);
  }

  .explore-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: none;
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
  }

  .explore-link:hover {
    color: var(--color-text);
    border-bottom: none;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 90vh;
      padding: var(--spacing-lg) var(--spacing-md);
    }

    .products-grid {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .hero-cta {
      flex-direction: column;
      align-items: center;
    }

    .posts-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-sm);
    }

    .showcase-section {
      min-height: 50vh;
    }
  }
</style>

<script is:inline>
  // 数字计数动画
  function initCounters() {
    const counters = document.querySelectorAll('[data-counter]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.dataset.counter);
          if (isNaN(target)) return;

          let current = 0;
          const increment = target / 40;
          const timer = setInterval(() => {
            current += increment;
            if (current >= target) {
              current = target;
              clearInterval(timer);
            }
            el.textContent = Math.floor(current);
          }, 30);

          observer.unobserve(el);
        }
      });
    }, { threshold: 0.5 });

    counters.forEach(c => observer.observe(c));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCounters);
  } else {
    initCounters();
  }
  document.addEventListener('astro:after-swap', initCounters);

  // 鼠标追踪光效
  document.addEventListener('mousemove', (e) => {
    const cards = document.querySelectorAll('.product-card');
    cards.forEach(card => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      card.style.setProperty('--mouse-x', `${x}px`);
      card.style.setProperty('--mouse-y', `${y}px`);
    });
  });
</script>
