---
import type { Post } from '@/utils/post';
import { formatDate } from '@/utils/post';
import { SITE_CONFIG } from '@/config';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, pubDate, category, tags } = post.data;
const categoryConfig = SITE_CONFIG.categories[category];
---

<article class="post-card">
  <div class="post-card-glow"></div>
  <div class="post-card-inner">
    <div class="post-meta">
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
      <span class="meta-dot"></span>
      <a href={`/category/${category}`} class="category-badge">{categoryConfig.displayName}</a>
    </div>

    <h2 class="post-title">
      <a href={`/blog/${post.slug}`}>{title}</a>
    </h2>

    <p class="post-description">{description}</p>

    {tags && tags.length > 0 && (
      <div class="post-tags">
        {tags.map(tag => (
          <a href={`/tags/${tag}`} class="tag">#{tag}</a>
        ))}
      </div>
    )}

    <a href={`/blog/${post.slug}`} class="read-more">
      Read more
      <svg class="arrow" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>

<style>
  .post-card {
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
    transition: background-color 0.3s ease;
  }

  .post-card:hover {
    background-color: var(--color-bg-card);
  }

  .post-card-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(
      600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(99, 102, 241, 0.06),
      transparent 40%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 0;
  }

  .post-card:hover .post-card-glow {
    opacity: 1;
  }

  .post-card-inner {
    padding: var(--spacing-lg) 0;
    max-width: 900px;
    position: relative;
    z-index: 1;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-sm);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meta-dot {
    width: 3px;
    height: 3px;
    background-color: var(--color-text-muted);
    border-radius: 50%;
  }

  .category-badge {
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .category-badge:hover {
    color: var(--color-primary-hover);
  }

  .post-title {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: var(--spacing-xs);
    letter-spacing: -0.02em;
  }

  .post-title a {
    color: var(--color-text);
    text-decoration: none;
    border-bottom: none;
    transition: color 0.2s ease;
  }

  .post-title a:hover {
    color: var(--color-primary-hover);
    border-bottom: none;
  }

  .post-description {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--spacing-sm);
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--spacing-sm);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: none;
    background-color: var(--color-bg-card);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    transition: all 0.2s ease;
  }

  .tag:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
    background-color: var(--color-bg-card-hover);
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: none;
    transition: all 0.3s ease;
  }

  .read-more .arrow {
    transition: transform 0.3s ease;
  }

  .read-more:hover {
    color: var(--color-text);
    border-bottom: none;
  }

  .read-more:hover .arrow {
    transform: translateX(4px);
  }
</style>

<script is:inline>
  // 鼠标追踪光效
  document.querySelectorAll('.post-card').forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
      card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
    });
  });
</script>
