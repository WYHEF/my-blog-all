---
import { SITE_CONFIG } from '@/config';

const currentPath = Astro.url.pathname;

function isActive(path: string) {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="logo">
      <svg class="logo-icon" viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
        <path d="M2.5 12C2.5 6.75 6.75 2.5 12 2.5S21.5 6.75 21.5 12 17.25 21.5 12 21.5 2.5 17.25 2.5 12zm9.5-6a6 6 0 100 12 6 6 0 000-12z"/>
      </svg>
      <span class="logo-text">{SITE_CONFIG.title}</span>
    </a>

    <nav class="nav">
      <ul class="nav-links">
        {SITE_CONFIG.navLinks.map(link => (
          <li>
            <a
              href={link.path}
              class:list={['nav-link', { active: isActive(link.path) }]}
            >
              {link.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-right">
      <a href={SITE_CONFIG.github} target="_blank" rel="noopener noreferrer" class="github-link" aria-label="GitHub">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <button id="mobile-menu-toggle" class="mobile-menu-btn" aria-label="菜单">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- 移动端菜单 -->
  <div id="mobile-menu" class="mobile-menu">
    <nav class="mobile-nav">
      {SITE_CONFIG.navLinks.map(link => (
        <a
          href={link.path}
          class:list={['mobile-nav-link', { active: isActive(link.path) }]}
        >
          {link.name}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 64px;
    background-color: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    z-index: 1000;
  }

  .header-inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 var(--spacing-lg);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text);
    text-decoration: none;
    border: none;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    margin-right: var(--spacing-xl);
    flex-shrink: 0;
  }

  .logo-icon {
    color: var(--color-text);
  }

  .logo:hover {
    border-bottom: none;
  }

  .nav {
    flex: 1;
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--spacing-lg);
  }

  .nav-link {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.5rem 0;
    border-bottom: none;
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text);
  }

  .header-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .github-link {
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    border-bottom: none;
    transition: color 0.2s ease;
  }

  .github-link:hover {
    color: var(--color-text);
    border-bottom: none;
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    padding: 0.5rem;
  }

  .mobile-menu {
    display: none;
    background-color: rgba(0, 0, 0, 0.95);
    border-bottom: 1px solid var(--color-border);
    padding: var(--spacing-md) var(--spacing-lg);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .mobile-nav-link {
    color: var(--color-text-secondary);
    font-size: 1rem;
    font-weight: 500;
    padding: 0.5rem 0;
    border-bottom: none;
  }

  .mobile-nav-link.active {
    color: var(--color-text);
  }

  @media (max-width: 900px) {
    .nav {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }

    .mobile-menu.open {
      display: block;
    }
  }
</style>

<script is:inline>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('open');
  });
</script>
