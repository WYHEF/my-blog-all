---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import FloatingTOC from '@components/FloatingTOC.astro';
import ScrollProgress from '@components/ScrollProgress.astro';
import Pagination from '@components/Pagination.astro';
import { formatDate, getAdjacentPosts } from '@/utils/post';
import { SITE_CONFIG } from '@/config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const { title, description, pubDate, updatedDate, category, tags, cover } = post.data;
const categoryConfig = SITE_CONFIG.categories[category];

const { prev, next } = await getAdjacentPosts(post.slug);
---

<BaseLayout
  title={title}
  description={description}
  image={cover}
  article={true}
  publishedTime={pubDate}
  tags={tags}
  headings={headings}
>
  <ScrollProgress />

  <div class="article-layout">
    <article class="post">
      <header class="post-header reveal-fade-up">
        <div class="post-meta">
          <a href={`/category/${category}`} class="category-tag gradient-text">
            {categoryConfig.displayName}
          </a>
          <time datetime={pubDate.toISOString()}>
            {formatDate(pubDate)}
          </time>
        </div>

        <h1 class="post-title gradient-text">{title}</h1>
        <p class="post-description">{description}</p>

        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => (
              <a href={`/tags/${tag}`} class="tag">#{tag}</a>
            ))}
          </div>
        )}

        {cover && (
          <img src={cover} alt={title} class="post-cover" loading="lazy">
        )}
      </header>

      <div class="post-content">
        <Content />

        {updatedDate && (
          <div class="post-updated">
            最后更新：{formatDate(updatedDate)}
          </div>
        )}
      </div>

      <div class="post-navigation reveal-fade-up">
        <Pagination
          prev={prev ? { title: prev.data.title, url: `/blog/${prev.slug}` } : undefined}
          next={next ? { title: next.data.title, url: `/blog/${next.slug}` } : undefined}
        />
      </div>
    </article>

    <!-- 浮动 TOC (桌面端) -->
    <aside class="toc-aside">
      <FloatingTOC headings={headings} />
    </aside>
  </div>
</BaseLayout>

<style>
  .article-layout {
    display: flex;
    gap: var(--spacing-xl);
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg);
    position: relative;
  }

  .post {
    flex: 1;
    max-width: var(--article-max-width);
    min-width: 0;
    font-size: var(--article-font-size);
    line-height: 1.8;
  }

  .toc-aside {
    width: 240px;
    flex-shrink: 0;
    display: block;
  }

  .post-header {
    margin-bottom: var(--spacing-xl);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
  }

  .category-tag {
    font-weight: 600;
    text-decoration: none;
    border-bottom: none;
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.15;
    margin-bottom: var(--spacing-md);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .post-description {
    font-size: 1.15em;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-lg);
    line-height: 1.6;
    font-style: italic;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--spacing-md);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: none;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    transition: all var(--transition-fast) ease;
  }

  :global(html.light) .tag {
    background: rgba(0, 0, 0, 0.03);
  }

  .tag:hover {
    color: var(--color-accent-2);
    border-color: var(--color-accent-2);
    border-bottom: 1px solid var(--color-accent-2);
  }

  .post-cover {
    width: 100%;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin-top: var(--spacing-lg);
    border: 1px solid var(--color-border);
  }

  .post-content {
    line-height: 1.8;
  }

  .post-content :global(h2) {
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    font-size: 1.8rem;
    font-weight: 700;
  }

  .post-content :global(h3) {
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
    font-size: 1.4rem;
    font-weight: 600;
  }

  .post-content :global(p) {
    margin-bottom: 1.5em;
  }

  .post-content :global(img) {
    margin: var(--spacing-lg) 0;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    width: 100%;
    border: 1px solid var(--color-border);
  }

  .post-content :global(pre) {
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    background: rgba(17, 17, 17, 0.8);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  :global(html.light) .post-content :global(pre) {
    background: rgba(242, 241, 234, 0.8);
  }

  .post-updated {
    margin-top: var(--spacing-xl);
    padding: var(--spacing-md);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  :global(html.light) .post-updated {
    background: rgba(0, 0, 0, 0.02);
  }

  .post-navigation {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 1024px) {
    .toc-aside {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .article-layout {
      padding: var(--spacing-md);
    }

    .post-title {
      font-size: 1.75rem;
    }

    .post-description {
      font-size: 1rem;
    }
  }
</style>
