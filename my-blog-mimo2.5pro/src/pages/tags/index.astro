---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getAllTags } from '@/utils/post';
import { SITE_CONFIG } from '@/config';

const tags = await getAllTags();
---

<BaseLayout
  title={`标签 - ${SITE_CONFIG.title}`}
  description="按标签浏览文章"
>
  <div class="tags-page">
    <header class="page-header reveal-fade-up">
      <div class="page-badge">Tags</div>
      <h1 class="page-title gradient-text">标签</h1>
      <p class="page-desc">共 {tags.length} 个标签</p>
    </header>

    <div class="tags-cloud reveal-stagger">
      {tags.map(({ tag, count }) => (
        <a
          href={`/tags/${tag}`}
          class="tag-item"
          style={`font-size: ${Math.min(0.85 + count * 0.12, 1.4)}rem;`}
        >
          <span class="tag-name">#{tag}</span>
          <span class="tag-count">{count}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .tags-page {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
    padding: var(--spacing-xl) 0;
  }

  .page-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-2);
    padding: 0.3rem 1rem;
    border: 1px solid var(--color-accent-2);
    border-radius: var(--radius-xl);
    margin-bottom: var(--spacing-md);
  }

  .page-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--spacing-md);
  }

  .page-desc {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
  }

  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-lg) 0;
  }

  .tag-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-weight: 500;
    text-decoration: none;
    border-bottom: none;
    padding: 0.4rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(4px);
    transition: all var(--transition-normal) ease;
  }

  :global(html.light) .tag-item {
    background: rgba(0, 0, 0, 0.02);
  }

  .tag-item:hover {
    color: var(--color-accent-2);
    border-color: var(--color-accent-2);
    transform: scale(1.05);
    box-shadow: 0 0 15px rgba(139, 92, 246, 0.15);
    border-bottom: 1px solid var(--color-accent-2);
  }

  .tag-name {
    line-height: 1;
  }

  .tag-count {
    font-size: 0.7em;
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15rem 0.4rem;
    border-radius: var(--radius-sm);
  }

  :global(html.light) .tag-count {
    background: rgba(0, 0, 0, 0.05);
  }

  @media (max-width: 768px) {
    .tags-page {
      padding: var(--spacing-lg) var(--spacing-md);
    }

    .tags-cloud {
      gap: 0.4rem;
    }
  }
</style>
