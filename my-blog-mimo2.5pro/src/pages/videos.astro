---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/config';

const videos = [
  { bvid: 'BV1wXQHYBEtt', title: '视频教程 1' },
  { bvid: 'BV1FJKezFETE', title: '视频教程 2' },
  { bvid: 'BV1GQKYzEEfs', title: '视频教程 3' },
  { bvid: 'BV1yqrNBoEh3', title: '视频教程 4' },
  { bvid: 'BV1m8rNBaEaX', title: '视频教程 5' },
  { bvid: 'BV1M8rNBYEj2', title: '视频教程 6' },
  { bvid: 'BV1ubrNBPEg3', title: '视频教程 7' },
  { bvid: 'BV1UbrNBAEGD', title: '视频教程 8' },
  { bvid: 'BV1UbrNBAE3n', title: '视频教程 9' },
  { bvid: 'BV12YrNB8EW8', title: '视频教程 10' },
  { bvid: 'BV1xYrNBhEZe', title: '视频教程 11' },
  { bvid: 'BV14YrNBhEqb', title: '视频教程 12' },
];
---

<BaseLayout
  title={`视频教程 - ${SITE_CONFIG.title}`}
  description={`${SITE_CONFIG.author}的B站视频教程合集`}
>
  <div class="videos-page">
    <header class="page-header reveal-fade-up">
      <div class="page-badge">Tutorials</div>
      <h1 class="page-title gradient-text">视频教程</h1>
      <p class="page-desc">
        我在 B 站发布的教程视频合集，欢迎
        <a href={SITE_CONFIG.bilibili} target="_blank" rel="noopener noreferrer">关注我的 B 站频道</a>
        获取更多内容。
      </p>
    </header>

    <div class="videos-grid reveal-stagger">
      {videos.map((video, index) => (
        <div class="video-card glass">
          <div class="video-wrapper">
            <iframe
              src={`//player.bilibili.com/player.html?bvid=${video.bvid}&page=1`}
              scrolling="no"
              border="0"
              frameborder="no"
              framespacing="0"
              allowfullscreen="true"
              loading="lazy"
            ></iframe>
          </div>
          <div class="video-info">
            <span class="video-index">#{index + 1}</span>
            <a
              href={`https://www.bilibili.com/video/${video.bvid}`}
              target="_blank"
              rel="noopener noreferrer"
              class="video-link"
            >
              在 B 站观看 →
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .videos-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
    padding: var(--spacing-xl) 0;
  }

  .page-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-2);
    padding: 0.3rem 1rem;
    border: 1px solid var(--color-accent-2);
    border-radius: var(--radius-xl);
    margin-bottom: var(--spacing-md);
  }

  .page-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--spacing-md);
  }

  .page-desc {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .page-desc a {
    color: var(--color-accent-2);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition-fast) ease;
  }

  .page-desc a:hover {
    border-bottom-color: var(--color-accent-2);
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }

  .video-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-normal) var(--ease-out),
                border-color var(--transition-normal) ease,
                box-shadow var(--transition-normal) ease;
  }

  .video-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-hover);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3), var(--shadow-glow);
  }

  :global(html.light) .video-card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08), var(--shadow-glow);
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 60%;
    overflow: hidden;
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-sm) var(--spacing-md);
  }

  .video-index {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .video-link {
    font-size: 0.85rem;
    color: var(--color-accent-2);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition-fast) ease;
  }

  .video-link:hover {
    border-bottom-color: var(--color-accent-2);
  }

  @media (max-width: 768px) {
    .videos-grid {
      grid-template-columns: 1fr;
    }

    .videos-page {
      padding: var(--spacing-lg) var(--spacing-md);
    }
  }
</style>
