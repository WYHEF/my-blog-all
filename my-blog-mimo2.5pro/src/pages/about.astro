---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/config';

const techStack = [
  { name: 'Python', percent: 100, color: '#6366f1', desc: '主要开发语言，用于脚本与自动化' },
  { name: 'Java', percent: 80, color: '#8b5cf6', desc: '熟悉 Java SE 及面向对象设计' },
  { name: 'JavaScript', percent: 70, color: '#a855f7', desc: '能够进行基本的前端开发' },
  { name: 'Vue', percent: 70, color: '#6366f1', desc: '熟悉 Vue 生态系统' },
  { name: 'SpringBoot', percent: 60, color: '#8b5cf6', desc: '具备后端服务开发能力' },
  { name: 'HTML/CSS', percent: 60, color: '#a855f7', desc: '页面布局与样式调整' },
  { name: 'C++', percent: 40, color: '#6366f1', desc: '算法学习与底层逻辑探索' },
];
---

<BaseLayout
  title={`关于 - ${SITE_CONFIG.title}`}
  description={`关于 ${SITE_CONFIG.author}`}
>
  <div class="about-page">
    <!-- Hero Section -->
    <header class="about-hero reveal-fade-up">
      <div class="hero-badge">关于我</div>
      <h1 class="about-title gradient-text">{SITE_CONFIG.author}</h1>
      <p class="about-subtitle">WYHEF · 记录技术、学习与生活</p>
    </header>

    <div class="about-layout">
      <!-- 左侧 Profile Card -->
      <aside class="profile-card glass reveal-fade-up">
        <div class="avatar-wrapper">
          <img src={SITE_CONFIG.avatar} alt={SITE_CONFIG.author} class="avatar">
        </div>

        <div class="profile-info">
          <h2 class="profile-name">{SITE_CONFIG.author}</h2>
          <p class="profile-handle">@WYHEF</p>
          <p class="profile-bio">热衷于探索代码背后的逻辑，享受构建工具来解决实际问题的过程。</p>
        </div>

        <div class="social-links">
          <a href={SITE_CONFIG.github} target="_blank" rel="noopener noreferrer" class="social-link" title="GitHub">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            GitHub
          </a>
          <a href={SITE_CONFIG.bilibili} target="_blank" rel="noopener noreferrer" class="social-link" title="Bilibili">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><rect x="2" y="7" width="20" height="13" rx="2" ry="2"></rect><path d="M17 2l-5 5-5-5"></path></svg>
            Bilibili
          </a>
          <a href={`mailto:${SITE_CONFIG.email}`} class="social-link" title="Email">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            {SITE_CONFIG.email}
          </a>
          <div class="social-link wechat-trigger" title="微信扫码关注">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><path d="M8.5 13.5l-1.5 2.5v-2.5h-1c-2.5 0-4.5-2-4.5-4.5s2-4.5 4.5-4.5 4.5 2 4.5 4.5c0 1-.5 2-1.5 3z"></path><path d="M17.5 12c-2.5 0-4.5 2-4.5 4.5s2 4.5 4.5 4.5c1 0 2-.5 2.5-1v1h2.5l-1.5-2.5c1-1 1.5-2 1.5-3 0-2.5-2-4.5-4.5-4.5z"></path></svg>
            <span>公众号：{SITE_CONFIG.wechat}</span>
            <div class="qr-popup glass-strong">
              <img src="/qrcode.jpg" alt="微信公众号二维码" class="qr-img">
              <span class="qr-tip">扫码关注</span>
            </div>
          </div>
        </div>
      </aside>

      <!-- 右侧 Content -->
      <article class="bio-content reveal-fade-up">
        <section class="bio-section">
          <h2 class="section-heading">你好，我是吴煜凡。</h2>
          <p>
            欢迎来到我的个人博客。我是一名热衷于计算机技术的开发者和学习者，ID 是 <strong>WYHEF</strong>（也就是五氧化二钒的缩写）。
          </p>
          <p>
            我热衷于探索代码背后的逻辑，同时也享受构建工具来解决实际问题的过程。目前，我主要关注后端开发、脚本自动化以及 Web 全栈技术。
          </p>
        </section>

        <section class="bio-section">
          <h3 class="section-heading">关于本站</h3>
          <p>
            建立这个博客的初衷是为了构建一个属于自己的知识库。在这个信息碎片化的时代，我希望通过长文写作来沉淀思考，记录学习过程中的灵光一现。
          </p>
          <p>在这里，你主要会看到以下内容：</p>
          <ul class="content-list">
            <li><strong>技术笔记</strong>：关于 Python, Java, SpringBoot 等技术的学习心得与踩坑记录。</li>
            <li><strong>项目实战</strong>：个人项目的开发过程复盘与技术总结。</li>
            <li><strong>算法与逻辑</strong>：在 C++ 算法学习过程中的思考。</li>
            <li><strong>生活随笔</strong>：关于旅行、阅读和生活的些许感悟。</li>
          </ul>
        </section>

        <section class="bio-section">
          <h3 class="section-heading">技术栈</h3>
          <div class="tech-stack">
            {techStack.map(tech => (
              <div class="tech-item">
                <div class="tech-header">
                  <span class="tech-name">{tech.name}</span>
                  <span class="tech-percent">{tech.percent}%</span>
                </div>
                <div class="tech-desc">{tech.desc}</div>
                <div class="progress-bar">
                  <div class="progress-fill" style={`width: ${tech.percent}%; background: linear-gradient(90deg, ${tech.color}, var(--color-accent-2));`}></div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section class="bio-section">
          <h3 class="section-heading">联系我</h3>
          <p>
            如果你对我的文章感兴趣，或者有技术问题想要交流，欢迎通过左侧的社交链接联系我。
            你也可以关注我的微信公众号 <strong>"五氧化二钒不是废钒"</strong>，获取更多动态。
          </p>
        </section>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  /* Hero */
  .about-hero {
    text-align: center;
    margin-bottom: var(--spacing-xl);
    padding: var(--spacing-xl) 0;
  }

  .hero-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-2);
    padding: 0.3rem 1rem;
    border: 1px solid var(--color-accent-2);
    border-radius: var(--radius-xl);
    margin-bottom: var(--spacing-md);
  }

  .about-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--spacing-sm);
  }

  .about-subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }

  /* Layout */
  .about-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--spacing-xl);
    align-items: start;
  }

  /* Profile Card */
  .profile-card {
    position: sticky;
    top: calc(var(--header-height) + var(--spacing-lg));
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .avatar-wrapper {
    width: 120px;
    height: 120px;
    margin: 0 auto var(--spacing-md);
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--color-border);
    transition: border-color var(--transition-normal) ease;
  }

  .avatar-wrapper:hover {
    border-color: var(--color-accent-2);
  }

  .avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-name {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: var(--color-text);
  }

  .profile-handle {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-accent-2);
    margin-bottom: var(--spacing-sm);
  }

  .profile-bio {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--spacing-lg);
  }

  /* Social Links */
  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    border-top: 1px solid var(--color-border);
    padding-top: var(--spacing-md);
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    text-decoration: none;
    border-bottom: none;
    transition: all var(--transition-fast) ease;
    cursor: pointer;
    position: relative;
    padding: 0.3rem 0;
  }

  .social-link:hover {
    color: var(--color-accent-2);
    border-bottom: none;
  }

  .social-link svg {
    opacity: 0.7;
    transition: opacity var(--transition-fast) ease;
  }

  .social-link:hover svg {
    opacity: 1;
  }

  /* WeChat QR */
  .wechat-trigger:hover .qr-popup {
    display: flex;
    animation: qr-fade-in 0.2s ease-out;
  }

  .qr-popup {
    display: none;
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding: 10px;
    border-radius: var(--radius-md);
    flex-direction: column;
    align-items: center;
    z-index: 100;
    margin-bottom: 10px;
    width: 150px;
  }

  .qr-img {
    width: 120px;
    height: 120px;
    object-fit: contain;
    margin-bottom: 5px;
    border-radius: var(--radius-sm);
  }

  .qr-tip {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  @keyframes qr-fade-in {
    from { opacity: 0; transform: translate(-50%, 10px); }
    to { opacity: 1; transform: translate(-50%, 0); }
  }

  /* Bio Content */
  .bio-content {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .bio-section {
    margin-bottom: var(--spacing-xl);
  }

  .section-heading {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--spacing-md);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  h2.section-heading {
    font-size: 1.75rem;
  }

  .bio-content p {
    margin-bottom: 1.5em;
    color: var(--color-text);
  }

  .content-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .content-list li {
    margin-bottom: 0.75rem;
    padding-left: 1.2rem;
    position: relative;
    line-height: 1.6;
    color: var(--color-text);
  }

  .content-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--color-accent-2);
    font-weight: bold;
  }

  /* Tech Stack */
  .tech-stack {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-top: 1rem;
  }

  .tech-item {
    padding: var(--spacing-sm) var(--spacing-md);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast) ease;
  }

  :global(html.light) .tech-item {
    background: rgba(0, 0, 0, 0.02);
  }

  .tech-item:hover {
    border-color: var(--color-border-hover);
  }

  .tech-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.2rem;
  }

  .tech-name {
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .tech-percent {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent-2);
  }

  .tech-desc {
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    margin-bottom: 0.5rem;
  }

  .progress-bar {
    width: 100%;
    height: 4px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    overflow: hidden;
  }

  :global(html.light) .progress-bar {
    background: rgba(0, 0, 0, 0.06);
  }

  .progress-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.8s ease-out;
  }

  @media (max-width: 768px) {
    .about-layout {
      grid-template-columns: 1fr;
    }

    .profile-card {
      position: static;
    }

    .about-page {
      padding: var(--spacing-lg) var(--spacing-md);
    }

    .qr-popup {
      left: 0;
      transform: none;
    }
  }
</style>
