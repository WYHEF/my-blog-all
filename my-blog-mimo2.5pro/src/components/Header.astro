---
import { SITE_CONFIG } from '@/config';
import ThemeToggle from './ThemeToggle.astro';
import FontResizer from './FontResizer.astro';

const currentPath = Astro.url.pathname;

function isActive(path: string) {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}
---

<header class="header" id="site-header">
  <div class="header-inner">
    <a href="/" class="logo gradient-text">
      {SITE_CONFIG.title}
    </a>

    <nav class="nav-desktop">
      <ul class="nav-links">
        {SITE_CONFIG.navLinks.map(link => (
          <li>
            <a
              href={link.path}
              class:list={['nav-link', { active: isActive(link.path) }]}
            >
              {link.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-right">
      <FontResizer />
      <ThemeToggle />
      <a href={SITE_CONFIG.github} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>

      <!-- 移动端汉堡菜单按钮 -->
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="打开菜单" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- 移动端全屏菜单 -->
  <div class="mobile-menu" id="mobile-menu">
    <nav class="mobile-nav">
      <ul class="mobile-nav-links">
        {SITE_CONFIG.navLinks.map(link => (
          <li>
            <a
              href={link.path}
              class:list={['mobile-nav-link', { active: isActive(link.path) }]}
            >
              {link.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
    z-index: 1000;
    transition: background var(--transition-normal) ease,
                box-shadow var(--transition-normal) ease;
  }

  :global(html.light) .header {
    background: rgba(250, 250, 248, 0.85);
  }

  .header.scrolled {
    box-shadow: var(--shadow-md);
  }

  .header-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 var(--spacing-lg);
    gap: var(--spacing-lg);
  }

  .logo {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    text-decoration: none;
    border: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-desktop {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--spacing-xs);
  }

  .nav-link {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-md);
    border-bottom: none;
    transition: all var(--transition-fast) ease;
  }

  .nav-link:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.05);
    border-bottom: none;
  }

  :global(html.light) .nav-link:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .nav-link.active {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.08);
  }

  :global(html.light) .nav-link.active {
    background: rgba(0, 0, 0, 0.06);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-shrink: 0;
  }

  .social-link {
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    border-bottom: none;
    padding: 0.4rem;
    border-radius: var(--radius-md);
    transition: color var(--transition-fast) ease;
  }

  .social-link:hover {
    color: var(--color-text);
    border-bottom: none;
  }

  /* 移动端汉堡菜单按钮 */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: 1px solid var(--color-border);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: var(--radius-md);
  }

  .hamburger-line {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--color-text-secondary);
    transition: all var(--transition-fast) ease;
    border-radius: 1px;
  }

  .mobile-menu-btn.open .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(4px, 4px);
  }

  .mobile-menu-btn.open .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-btn.open .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(4px, -4px);
  }

  /* 移动端全屏菜单 */
  .mobile-menu {
    display: none;
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 999;
    opacity: 0;
    transform: translateY(-10px);
    transition: opacity var(--transition-normal) ease,
                transform var(--transition-normal) var(--ease-out);
    pointer-events: none;
  }

  :global(html.light) .mobile-menu {
    background: rgba(250, 250, 248, 0.95);
  }

  .mobile-menu.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .mobile-nav {
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  .mobile-nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .mobile-nav-link {
    display: block;
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-fast) ease;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--color-text);
  }

  @media (max-width: 1024px) {
    .nav-desktop {
      display: none;
    }

    .social-link {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }
  }

  @media (max-width: 768px) {
    .header-inner {
      padding: 0 var(--spacing-md);
    }
  }
</style>

<script>
  import { register, type AnimationModule } from '@/scripts/view-transition-manager';

  const headerModule: AnimationModule = {
    scrollHandler: null as (() => void) | null,

    init() {
      const header = document.getElementById('site-header');
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      // 滚动时添加阴影
      this.scrollHandler = () => {
        if (window.scrollY > 10) {
          header?.classList.add('scrolled');
        } else {
          header?.classList.remove('scrolled');
        }
      };
      window.addEventListener('scroll', this.scrollHandler, { passive: true });

      // 移动端菜单切换
      menuBtn?.addEventListener('click', () => {
        const isOpen = menuBtn.classList.toggle('open');
        mobileMenu?.classList.toggle('open');
        menuBtn.setAttribute('aria-expanded', String(isOpen));
      });

      // 点击菜单链接后关闭菜单
      document.querySelectorAll('.mobile-nav-link').forEach(link => {
        link.addEventListener('click', () => {
          menuBtn?.classList.remove('open');
          mobileMenu?.classList.remove('open');
          menuBtn?.setAttribute('aria-expanded', 'false');
        });
      });
    },

    destroy() {
      if (this.scrollHandler) {
        window.removeEventListener('scroll', this.scrollHandler);
      }
    }
  };

  register(headerModule);
</script>
