---
import GlowOrb from '@components/landing/GlowOrb.astro';

interface LatestPost {
  title: string;
  url: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  latestPost?: LatestPost;
}

const {
  title = 'yufan',
  subtitle = 'WYHEF · 五氧化二钒不是废钒',
  latestPost,
} = Astro.props;
---

<section class="hero">
  <!-- 右上白蓝主光晕 -->
  <GlowOrb
    top="-220px"
    right="-180px"
    size="900px"
    color="var(--glow-blue)"
    blur="100px"
    opacity={0.55}
    parallax
    parallaxStrength={0.022}
  />
  <!-- 左下紫色辅光 -->
  <GlowOrb
    bottom="-360px"
    left="-260px"
    size="700px"
    color="var(--glow-violet)"
    blur="130px"
    opacity={0.32}
    parallax
    parallaxStrength={0.012}
  />

  <div class="hero-inner">
    <p class="hero-eyebrow">WELCOME · 欢迎</p>
    <h1 class="hero-title" aria-label={title}>
      <span class="hero-title-text">{title}</span>
    </h1>
    <p class="hero-subtitle">{subtitle}</p>

    <div class="hero-search-wrap">
      <button
        class="hero-search"
        type="button"
        data-search-trigger
        aria-label="搜索文章"
      >
        <svg class="hero-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <span class="hero-search-placeholder">What do you want to read?</span>
        <span class="hero-search-action" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </span>
      </button>
    </div>
  </div>

  <div class="hero-footer">
    <a href="#sections" class="hero-scroll" aria-label="向下滚动">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14"></path>
        <path d="m19 12-7 7-7-7"></path>
      </svg>
      <span class="visually-hidden">向下滚动</span>
    </a>

    {latestPost && (
      <a href={latestPost.url} class="hero-announcement">
        <span class="hero-announcement-label">Latest post</span>
        <span class="hero-announcement-text">{latestPost.title}</span>
        <span class="hero-announcement-cta">
          READ
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </span>
      </a>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: calc(var(--header-height) + var(--spacing-xl)) var(--spacing-lg) var(--spacing-xl);
    overflow: hidden;
    isolation: isolate;
  }

  /* 背景星空(伪装) - 一些发光点 */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 12% 22%, rgba(255, 255, 255, 0.5), transparent 50%),
      radial-gradient(1px 1px at 28% 64%, rgba(255, 255, 255, 0.4), transparent 50%),
      radial-gradient(1.5px 1.5px at 48% 18%, rgba(255, 255, 255, 0.6), transparent 50%),
      radial-gradient(1px 1px at 76% 44%, rgba(255, 255, 255, 0.4), transparent 50%),
      radial-gradient(1.5px 1.5px at 88% 78%, rgba(255, 255, 255, 0.5), transparent 50%),
      radial-gradient(1px 1px at 62% 86%, rgba(255, 255, 255, 0.35), transparent 50%);
    pointer-events: none;
    z-index: -1;
    animation: stars-twinkle 6s ease-in-out infinite alternate;
  }

  @keyframes stars-twinkle {
    from { opacity: 0.6; }
    to   { opacity: 1; }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ---------- Eyebrow ---------- */
  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-lg);
    opacity: 0;
    animation: hero-fade-up 1s var(--ease-smooth) 0.2s forwards;
  }

  /* ---------- 主标题 yufan 巨字 ---------- */
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(96px, 18vw, 280px);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin: 0;
    position: relative;
    will-change: filter, opacity, transform;
  }

  .hero-title-text {
    display: inline-block;
    background: linear-gradient(
      120deg,
      rgba(255, 255, 255, 0.55) 0%,
      #ffffff 28%,
      rgba(255, 255, 255, 0.55) 56%,
      #ffffff 84%,
      rgba(255, 255, 255, 0.55) 100%
    );
    background-size: 220% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    /* 入场:模糊渐显 */
    opacity: 0;
    filter: blur(38px);
    transform: translateY(20px);
    animation:
      hero-title-in 1.4s var(--ease-smooth) 0.3s forwards,
      hero-title-shine 9s linear 1.7s infinite;
  }

  @keyframes hero-title-in {
    0%   { opacity: 0; filter: blur(38px); transform: translateY(20px); }
    100% { opacity: 1; filter: blur(0);     transform: translateY(0); }
  }

  @keyframes hero-title-shine {
    0%   { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }

  /* ---------- 副标题 ---------- */
  .hero-subtitle {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
    opacity: 0;
    animation: hero-fade-up 1s var(--ease-smooth) 0.9s forwards;
  }

  /* ---------- 搜索框 ---------- */
  .hero-search-wrap {
    width: 100%;
    max-width: 480px;
    opacity: 0;
    animation: hero-fade-up 1s var(--ease-smooth) 1.1s forwards;
  }

  .hero-search {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.85rem 1rem;
    cursor: text;
    color: var(--color-text-tertiary);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    text-align: left;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color var(--duration-fast) var(--ease-smooth),
                background-color var(--duration-fast) var(--ease-smooth),
                box-shadow var(--duration-fast) var(--ease-smooth);
  }

  .hero-search:hover,
  .hero-search:focus-visible {
    border-color: var(--color-border-strong);
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text-secondary);
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.04);
    outline: none;
  }

  .hero-search-icon {
    flex-shrink: 0;
  }

  .hero-search-placeholder {
    flex: 1;
    text-align: left;
  }

  .hero-search-action {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--color-text);
    color: var(--color-bg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform var(--duration-fast) var(--ease-smooth);
  }

  .hero-search:hover .hero-search-action {
    transform: translateX(3px);
  }

  /* ---------- 底部条 ---------- */
  .hero-footer {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--spacing-lg);
    gap: var(--spacing-md);
    z-index: 1;
    opacity: 0;
    animation: hero-fade-up 1s var(--ease-smooth) 1.4s forwards;
  }

  .hero-scroll {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--ease-smooth),
                color var(--duration-fast) var(--ease-smooth),
                transform var(--duration-base) var(--ease-smooth);
    animation: scroll-bounce 2.5s ease-in-out infinite;
  }

  .hero-scroll:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(4px); }
  }

  .hero-announcement {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-text-secondary);
    font-size: 0.78rem;
    text-decoration: none;
    border: none;
    padding: 0.55rem 1rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    max-width: min(560px, 70vw);
    transition: border-color var(--duration-fast) var(--ease-smooth),
                background-color var(--duration-fast) var(--ease-smooth);
  }

  .hero-announcement:hover {
    border-color: var(--color-border-strong);
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text);
  }

  .hero-announcement-label {
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.7rem;
    flex-shrink: 0;
  }

  .hero-announcement-text {
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 500;
  }

  .hero-announcement-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    border-left: 1px solid var(--color-border);
    padding-left: 0.7rem;
    flex-shrink: 0;
  }

  /* ---------- 通用入场 ---------- */
  @keyframes hero-fade-up {
    0%   { opacity: 0; transform: translateY(12px); }
    100% { opacity: 1; transform: none; }
  }

  /* ---------- 响应式 ---------- */
  @media (max-width: 768px) {
    .hero-footer {
      flex-direction: column-reverse;
      align-items: stretch;
      bottom: 20px;
    }

    .hero-announcement {
      max-width: 100%;
      font-size: 0.72rem;
    }

    .hero-announcement-label {
      display: none;
    }

    .hero-scroll {
      align-self: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title-text,
    .hero-eyebrow,
    .hero-subtitle,
    .hero-search-wrap,
    .hero-footer {
      opacity: 1;
      filter: none;
      transform: none;
      animation: none;
    }

    .hero-scroll,
    .hero::before {
      animation: none;
    }
  }
</style>
