---
// 星空粒子 Canvas - 模拟 x.ai 中部 "Understand The Universe" 区域的粒子爆炸 + 悬浮效果
// 进入视口才启动 RAF;离开视口暂停;支持 prefers-reduced-motion
interface Props {
  particleCount?: number;
  class?: string;
}

const { particleCount = 100, class: className = '' } = Astro.props;
---

<div class:list={['starfield', className]} data-particle-count={particleCount}>
  <canvas class="starfield-canvas" aria-hidden="true"></canvas>
  <div class="starfield-core" aria-hidden="true"></div>
</div>

<style>
  .starfield {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    max-width: 720px;
    margin: 0 auto;
  }

  .starfield-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* 中心点亮点 */
  .starfield-core {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 6px;
    height: 6px;
    background: #ffffff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 24px rgba(255, 255, 255, 0.7), 0 0 40px rgba(120, 170, 255, 0.5);
    pointer-events: none;
    opacity: 0;
    animation: core-pulse 4s ease-in-out infinite;
  }

  .starfield.is-active .starfield-core {
    opacity: 1;
  }

  @keyframes core-pulse {
    0%, 100% { box-shadow: 0 0 24px rgba(255, 255, 255, 0.7), 0 0 40px rgba(120, 170, 255, 0.5); }
    50%      { box-shadow: 0 0 32px rgba(255, 255, 255, 0.9), 0 0 60px rgba(120, 170, 255, 0.7); }
  }

  @media (prefers-reduced-motion: reduce) {
    .starfield-core {
      animation: none;
    }
  }
</style>

<script>
  interface Particle {
    angle: number;
    radius: number;
    targetRadius: number;
    angleSpeed: number;
    radiusSpeed: number;
    radiusOscillation: number;
    radiusOscillationOffset: number;
    size: number;
    opacity: number;
    spawnDelay: number;
    spawnProgress: number;
  }

  function initStarfield(host: HTMLElement) {
    const canvas = host.querySelector<HTMLCanvasElement>('.starfield-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const requested = parseInt(host.dataset.particleCount || '100', 10);
    const COUNT = reduced ? 0 : requested;
    const CONNECT_DIST = 90;

    let particles: Particle[] = [];
    let raf = 0;
    let active = false;
    let dpr = window.devicePixelRatio || 1;
    let cssWidth = 0;
    let cssHeight = 0;
    let centerX = 0;
    let centerY = 0;
    let startTime = 0;

    function resize() {
      const rect = host.getBoundingClientRect();
      cssWidth = rect.width;
      cssHeight = rect.height;
      dpr = window.devicePixelRatio || 1;
      canvas!.width = Math.floor(cssWidth * dpr);
      canvas!.height = Math.floor(cssHeight * dpr);
      canvas!.style.width = cssWidth + 'px';
      canvas!.style.height = cssHeight + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      centerX = cssWidth / 2;
      centerY = cssHeight / 2;
    }

    function makeParticles() {
      particles = [];
      const minR = Math.min(cssWidth, cssHeight) * 0.18;
      const maxR = Math.min(cssWidth, cssHeight) * 0.46;
      for (let i = 0; i < COUNT; i++) {
        const angle = Math.random() * Math.PI * 2;
        const target = minR + Math.random() * (maxR - minR);
        particles.push({
          angle,
          radius: 0,
          targetRadius: target,
          angleSpeed: (Math.random() - 0.5) * 0.0008,
          radiusSpeed: 0,
          radiusOscillation: 6 + Math.random() * 12,
          radiusOscillationOffset: Math.random() * Math.PI * 2,
          size: 0.8 + Math.random() * 1.6,
          opacity: 0.45 + Math.random() * 0.5,
          spawnDelay: Math.random() * 200,
          spawnProgress: 0,
        });
      }
    }

    function easeOutCubic(t: number): number {
      return 1 - Math.pow(1 - t, 3);
    }

    function draw() {
      if (!ctx) return;
      ctx.clearRect(0, 0, cssWidth, cssHeight);

      const t = (performance.now() - startTime) / 1000; // 秒
      const positions: Array<{ x: number; y: number; o: number }> = [];

      for (const p of particles) {
        // 入场动画:每个粒子有自己的延迟,scaledTime 0~1 内做扩散
        const localT = (performance.now() - startTime - p.spawnDelay) / 900;
        if (localT < 0) {
          continue; // 还没到出生时间
        }
        p.spawnProgress = Math.min(localT, 1);
        const ease = easeOutCubic(p.spawnProgress);

        // 悬浮:加少量振荡 + 角度漂移
        const oscillation = Math.sin(t * 0.6 + p.radiusOscillationOffset) * p.radiusOscillation;
        const baseR = p.targetRadius * ease + oscillation * (p.spawnProgress);
        p.angle += p.angleSpeed;

        const x = centerX + Math.cos(p.angle) * baseR;
        const y = centerY + Math.sin(p.angle) * baseR;
        const o = p.opacity * p.spawnProgress;

        positions.push({ x, y, o });

        // 画粒子
        ctx.beginPath();
        ctx.fillStyle = `rgba(255, 255, 255, ${o})`;
        ctx.arc(x, y, p.size, 0, Math.PI * 2);
        ctx.fill();
      }

      // 画粒子之间连线 (对邻近粒子)
      for (let i = 0; i < positions.length; i++) {
        const a = positions[i];
        // 与中心点的连线(若距离够近)
        const dxc = a.x - centerX;
        const dyc = a.y - centerY;
        const distC = Math.hypot(dxc, dyc);
        if (distC < CONNECT_DIST * 1.4) {
          const o = (1 - distC / (CONNECT_DIST * 1.4)) * 0.18 * a.o;
          ctx.strokeStyle = `rgba(180, 200, 255, ${o})`;
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(centerX, centerY);
          ctx.lineTo(a.x, a.y);
          ctx.stroke();
        }
        // 粒子之间近距离连线
        for (let j = i + 1; j < positions.length; j++) {
          const b = positions[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const dist = Math.hypot(dx, dy);
          if (dist < CONNECT_DIST) {
            const o = (1 - dist / CONNECT_DIST) * 0.12 * Math.min(a.o, b.o);
            ctx.strokeStyle = `rgba(255, 255, 255, ${o})`;
            ctx.lineWidth = 0.5;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }

      raf = requestAnimationFrame(draw);
    }

    function start() {
      if (active || COUNT === 0) return;
      active = true;
      host.classList.add('is-active');
      startTime = performance.now();
      makeParticles();
      raf = requestAnimationFrame(draw);
    }

    function stop() {
      if (!active) return;
      active = false;
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
    }

    // 进入视口才启动
    resize();
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              start();
            } else {
              stop();
            }
          });
        },
        { threshold: 0.15 }
      );
      io.observe(host);
    } else {
      start();
    }

    // 视口尺寸变化时重置
    let resizeTimer: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        const wasActive = active;
        stop();
        resize();
        if (wasActive) {
          startTime = performance.now();
          makeParticles();
          start();
        }
      }, 200);
    });

    // 静态降级 (reduced motion):仅画一帧
    if (reduced) {
      makeParticles();
      // 跳过入场动画,直接到目标半径
      particles.forEach((p) => {
        p.spawnProgress = 1;
        p.spawnDelay = 0;
      });
      startTime = performance.now() - 1000;
      draw();
      cancelAnimationFrame(raf);
    }
  }

  function init() {
    document.querySelectorAll<HTMLElement>('.starfield').forEach((el) => initStarfield(el));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
