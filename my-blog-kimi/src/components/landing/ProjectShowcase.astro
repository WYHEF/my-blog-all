---
// 推广位 - 对应 x.ai "SuperGrok" 板块
// 推广交互项目: KMP 算法可视化(主推) + 星煜凡程作为副卡
import GlowOrb from '@components/landing/GlowOrb.astro';
---

<section class="project-section">
  <!-- 背景 暖色 + 蓝色 双光晕,营造柔和渐光场 -->
  <GlowOrb
    bottom="-180px"
    left="-200px"
    size="800px"
    color="var(--glow-warm)"
    blur="180px"
    opacity={0.45}
    breathe
  />
  <GlowOrb
    top="-180px"
    right="-180px"
    size="700px"
    color="var(--glow-blue)"
    blur="180px"
    opacity={0.35}
    breathe
  />

  <header class="project-header" data-reveal>
    <span class="eyebrow">PROJECTS</span>
    <h2 class="project-headline">Build, don't just describe.</h2>
    <p class="project-lede">
      除了写字之外,我也写交互项目。下面是当前推荐试玩的两个 demo。
    </p>
  </header>

  <div class="project-stage">
    <!-- 主推:KMP 算法可视化 -->
    <a href="/projects" class="project-card project-card--featured" data-reveal data-reveal-delay="1">
      <div class="project-card-meta">
        <span class="project-card-badge">FEATURED</span>
        <span class="project-card-tags">algorithm · canvas · interactive</span>
      </div>

      <h3 class="project-card-title">KMP 算法可视化</h3>
      <p class="project-card-sub">
        Visualize the Knuth&ndash;Morris&ndash;Pratt string matcher.
      </p>
      <p class="project-card-desc">
        把 KMP 的 next 数组、跳转、匹配过程画成可一步一步推进的动画。
        输入任意字符串,实时观察指针怎么"跳"。
      </p>

      <div class="project-card-preview" aria-hidden="true">
        <div class="kmp-grid">
          <span class="kmp-cell kmp-cell--a">A</span>
          <span class="kmp-cell kmp-cell--b">B</span>
          <span class="kmp-cell kmp-cell--a">A</span>
          <span class="kmp-cell kmp-cell--b kmp-cell--match">B</span>
          <span class="kmp-cell kmp-cell--c">C</span>
          <span class="kmp-cell kmp-cell--a">A</span>
          <span class="kmp-cell kmp-cell--b">B</span>
          <span class="kmp-cell kmp-cell--a">A</span>
          <span class="kmp-cell kmp-cell--b">B</span>
          <span class="kmp-cell kmp-cell--a">A</span>
        </div>
        <div class="kmp-pointer">
          <span class="kmp-arrow"></span>
          <span class="kmp-pointer-label">i = 3</span>
        </div>
      </div>

      <span class="project-card-cta">
        TRY NOW
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </span>
    </a>

    <!-- 副推:星煜凡程 -->
    <a href="/projects" class="project-card project-card--secondary" data-reveal data-reveal-delay="2">
      <div class="project-card-meta">
        <span class="project-card-badge project-card-badge--alt">SIDE PROJECT</span>
        <span class="project-card-tags">brand · creative · ai</span>
      </div>

      <h3 class="project-card-title">星煜凡程</h3>
      <p class="project-card-sub">
        A personal label for AI-driven creative side projects.
      </p>
      <p class="project-card-desc">
        把零散的小工具、视觉实验、AI 工作流整合成一个长期更新的 brand,
        持续投放新作品。
      </p>

      <div class="project-card-orb" aria-hidden="true"></div>

      <span class="project-card-cta">
        EXPLORE
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </span>
    </a>
  </div>
</section>

<style>
  .project-section {
    position: relative;
    padding: var(--section-pad) var(--spacing-lg);
    max-width: 1280px;
    margin: 0 auto;
    overflow: hidden;
    isolation: isolate;
  }

  .project-header {
    max-width: 720px;
    margin: 0 auto var(--spacing-xl);
    text-align: center;
  }

  .project-headline {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-text);
    margin: 0 0 var(--spacing-sm);
  }

  .project-lede {
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  /* ---------- 双卡片网格 ---------- */
  .project-stage {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--spacing-md);
    align-items: stretch;
  }

  /* ---------- 通用卡片 ---------- */
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 2rem 2rem 1.6rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    min-height: 420px;
    transition: border-color var(--duration-base) var(--ease-smooth),
                transform var(--duration-base) var(--ease-smooth),
                box-shadow var(--duration-base) var(--ease-smooth);
  }

  .project-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-4px);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08),
                0 30px 80px -20px rgba(120, 170, 255, 0.25);
  }

  /* 主推卡片渐光底 */
  .project-card--featured {
    background:
      radial-gradient(ellipse 120% 80% at 70% 110%, rgba(255, 138, 61, 0.18), transparent 60%),
      radial-gradient(ellipse 90% 80% at 10% -10%, rgba(120, 170, 255, 0.22), transparent 55%),
      linear-gradient(180deg, #0d0d0d 0%, #050505 100%);
  }

  /* 副推卡片更暗 */
  .project-card--secondary {
    background:
      radial-gradient(ellipse 100% 80% at 80% 120%, rgba(180, 140, 255, 0.18), transparent 60%),
      linear-gradient(180deg, #0a0a0a 0%, #040404 100%);
  }

  /* ---------- 卡片元信息 ---------- */
  .project-card-meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }

  .project-card-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--color-bg);
    background: var(--color-text);
    padding: 0.18rem 0.55rem;
    border-radius: var(--radius-pill);
  }

  .project-card-badge--alt {
    background: transparent;
    border: 1px solid var(--color-border-strong);
    color: var(--color-text);
  }

  .project-card-tags {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.08em;
  }

  .project-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    font-weight: 500;
    letter-spacing: -0.025em;
    margin: 0;
    color: var(--color-text);
  }

  .project-card-sub {
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin: 0;
    line-height: 1.5;
  }

  .project-card-desc {
    color: var(--color-text-tertiary);
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0.2rem 0 0;
    max-width: 56ch;
  }

  /* ---------- 主推卡片预览图: KMP 字符格栅 ---------- */
  .project-card-preview {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: var(--spacing-sm);
    margin: var(--spacing-md) 0;
    position: relative;
  }

  .kmp-grid {
    display: inline-flex;
    gap: 6px;
    padding: 0.6rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .kmp-cell {
    width: 36px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: background-color 0.4s var(--ease-smooth);
  }

  .kmp-cell--match {
    background: rgba(120, 170, 255, 0.25);
    border-color: rgba(120, 170, 255, 0.6);
    color: #ffffff;
    box-shadow: 0 0 16px rgba(120, 170, 255, 0.35);
    animation: kmp-pulse 2.4s ease-in-out infinite;
  }

  @keyframes kmp-pulse {
    0%, 100% { box-shadow: 0 0 12px rgba(120, 170, 255, 0.25); }
    50%      { box-shadow: 0 0 24px rgba(120, 170, 255, 0.55); }
  }

  .kmp-pointer {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
  }

  .kmp-arrow {
    width: 14px;
    height: 14px;
    border: 1px solid var(--color-text-secondary);
    border-bottom: none;
    border-right: none;
    transform: rotate(45deg) translate(2px, 2px);
    border-radius: 1px;
  }

  .kmp-pointer-label {
    color: var(--color-text-secondary);
  }

  /* ---------- 副推卡片光球装饰 ---------- */
  .project-card-orb {
    position: absolute;
    bottom: -120px;
    right: -120px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(180, 140, 255, 0.45), transparent 65%);
    filter: blur(70px);
    pointer-events: none;
    z-index: -1;
    animation: project-orb-breathe 9s ease-in-out infinite;
  }

  @keyframes project-orb-breathe {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50%      { transform: scale(1.06); opacity: 0.85; }
  }

  /* ---------- CTA ---------- */
  .project-card-cta {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    background: var(--color-text);
    color: var(--color-bg);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: gap var(--duration-fast) var(--ease-smooth);
  }

  .project-card:hover .project-card-cta {
    gap: 0.85rem;
  }

  /* ---------- 响应式 ---------- */
  @media (max-width: 960px) {
    .project-stage {
      grid-template-columns: 1fr;
    }

    .project-card {
      min-height: 320px;
    }
  }

  @media (max-width: 600px) {
    .kmp-cell {
      width: 30px;
      height: 38px;
      font-size: 0.85rem;
    }

    .kmp-grid {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
