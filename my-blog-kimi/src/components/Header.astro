---
import { SITE_CONFIG } from '@/config';

const currentPath = Astro.url.pathname;

// 辅助函数:检查链接是否激活
function isActive(path: string) {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}
---

<header class="header" id="site-header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="返回首页">
      <span class="logo-mark">y</span>
      <span class="logo-text">yufan</span>
    </a>

    <nav class="nav" aria-label="主导航">
      <ul class="nav-links">
        {SITE_CONFIG.navLinks.map(link => (
          <li>
            <a
              href={link.path}
              class:list={['nav-link', { active: isActive(link.path) }]}
            >
              {link.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-right">
      <button class="icon-btn search-trigger" data-search-trigger aria-label="搜索 (Ctrl+K)" type="button">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <span class="search-kbd">⌘K</span>
      </button>
      <a href={SITE_CONFIG.github} target="_blank" rel="noopener noreferrer" class="cta-btn">
        TRY GITHUB
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background-color: transparent;
    z-index: 1000;
    transition: background-color var(--duration-base) var(--ease-smooth),
                backdrop-filter var(--duration-base) var(--ease-smooth),
                border-color var(--duration-base) var(--ease-smooth);
    border-bottom: 1px solid transparent;
  }

  .header.scrolled {
    background-color: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--color-border);
  }

  .header-inner {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 var(--spacing-lg);
    gap: var(--spacing-md);
  }

  /* ---------- Logo ---------- */
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text);
    text-decoration: none;
    border: none;
    margin-right: var(--spacing-md);
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .logo-mark {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1;
    display: inline-block;
    transform: translateY(-1px);
  }

  .logo-text {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
  }

  /* ---------- 导航 ---------- */
  .nav {
    flex: 1;
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: clamp(0.75rem, 1.5vw, 1.5rem);
  }

  .nav-link {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    font-weight: 400;
    text-decoration: none;
    padding: 0.4rem 0;
    border: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: color var(--duration-fast) var(--ease-smooth);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text);
  }

  /* ---------- 右侧 ---------- */
  .header-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .icon-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    padding: 0.4rem 0.7rem;
    border-radius: var(--radius-md);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    transition: border-color var(--duration-fast) var(--ease-smooth),
                color var(--duration-fast) var(--ease-smooth);
  }

  .icon-btn:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }

  .search-kbd {
    opacity: 0.7;
    letter-spacing: 0.05em;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    background: var(--color-text);
    color: var(--color-bg);
    border: 1px solid var(--color-text);
    padding: 0.45rem 0.9rem;
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-smooth);
  }

  .cta-btn:hover {
    opacity: 0.85;
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  /* ---------- 响应式 ---------- */
  @media (max-width: 1024px) {
    .nav-links {
      gap: 0.85rem;
    }
  }

  @media (max-width: 768px) {
    .header-inner {
      padding: 0 var(--spacing-md);
    }

    .nav {
      display: none;
    }

    .search-kbd {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .cta-btn {
      display: none;
    }
  }
</style>

<script is:inline>
  // 滚动时切换 .scrolled 类
  (function () {
    const header = document.getElementById('site-header');
    if (!header) return;

    const update = () => {
      if (window.scrollY > 24) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };

    update();
    window.addEventListener('scroll', update, { passive: true });
  })();
</script>
