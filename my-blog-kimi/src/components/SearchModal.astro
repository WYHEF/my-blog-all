---
// 全站搜索模态层
// 触发方式:
// 1. 点击任意带 [data-search-trigger] 属性的元素
// 2. 全局快捷键 Ctrl/Cmd + K
// ESC 关闭
---

<div class="search-modal" id="search-modal" role="dialog" aria-modal="true" aria-labelledby="search-modal-title" hidden>
  <div class="search-modal-backdrop" data-search-close></div>

  <div class="search-modal-panel">
    <header class="search-modal-header">
      <svg class="search-modal-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.35-4.35"></path>
      </svg>
      <input
        id="search-modal-input"
        class="search-modal-input"
        type="text"
        placeholder="What do you want to read?"
        aria-label="搜索文章"
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="search-modal-kbd">ESC</kbd>
    </header>

    <div class="search-modal-body">
      <div id="search-modal-status" class="search-modal-status">
        <span class="search-modal-hint">输入关键字搜索文章…匹配标题、描述、标签</span>
      </div>
      <ul id="search-modal-results" class="search-modal-results" role="listbox"></ul>
    </div>

    <footer class="search-modal-footer">
      <span><kbd>↵</kbd> 打开</span>
      <span><kbd>↑</kbd><kbd>↓</kbd> 切换</span>
      <span><kbd>ESC</kbd> 关闭</span>
    </footer>
  </div>
</div>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-base) var(--ease-smooth);
  }

  .search-modal[hidden] {
    display: none;
  }

  .search-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .search-modal-backdrop {
    position: absolute;
    inset: 0;
    background-color: var(--color-bg-overlay);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .search-modal-panel {
    position: relative;
    width: min(600px, 92vw);
    max-height: 70vh;
    background-color: #0a0a0a;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-lg);
    box-shadow: 0 30px 80px -20px rgba(0, 0, 0, 0.8),
                0 0 0 1px rgba(255, 255, 255, 0.04);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateY(-12px);
    transition: transform var(--duration-base) var(--ease-smooth);
  }

  .search-modal.is-open .search-modal-panel {
    transform: none;
  }

  /* ---------- Header ---------- */
  .search-modal-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .search-modal-icon {
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }

  .search-modal-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-text);
    font-size: 1rem;
    font-family: var(--font-sans);
    padding: 0.2rem 0;
  }

  .search-modal-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .search-modal-kbd {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.4rem;
    line-height: 1;
  }

  /* ---------- Body ---------- */
  .search-modal-body {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem;
    min-height: 100px;
  }

  .search-modal-status {
    padding: 1rem;
    color: var(--color-text-tertiary);
    font-size: 0.85rem;
    text-align: center;
  }

  .search-modal-hint {
    color: var(--color-text-tertiary);
  }

  .search-modal-results {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  /* 单条结果 */
  .search-result-item {
    border-radius: var(--radius-md);
    transition: background-color var(--duration-fast) var(--ease-smooth);
  }

  .search-result-item a {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.7rem 0.85rem;
    color: var(--color-text);
    text-decoration: none;
    border: none;
  }

  .search-result-item.is-active,
  .search-result-item a:hover {
    background-color: rgba(255, 255, 255, 0.06);
  }

  .search-result-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .search-result-desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-result-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.2rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ---------- Footer ---------- */
  .search-modal-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 1rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
  }

  .search-modal-footer kbd {
    font-family: var(--font-mono);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.1rem 0.35rem;
    margin-right: 0.3rem;
  }

  /* ---------- 响应式 ---------- */
  @media (max-width: 600px) {
    .search-modal {
      padding-top: 8vh;
    }

    .search-modal-footer {
      flex-wrap: wrap;
      gap: 0.5rem;
    }
  }
</style>

<script>
  interface SearchItem {
    title: string;
    description: string;
    url: string;
    category: string;
    tags: string[];
  }

  const CATEGORY_LABELS: Record<string, string> = {
    tech: 'TECH',
    notes: 'NOTES',
    travel: 'TRAVEL',
  };

  let searchData: SearchItem[] = [];
  let dataLoaded = false;
  let activeIndex = 0;

  // 加载搜索数据
  async function loadSearchData() {
    if (dataLoaded) return;
    try {
      const res = await fetch('/search-data.json');
      searchData = await res.json();
      dataLoaded = true;
    } catch (err) {
      console.error('Failed to load search data:', err);
    }
  }

  function search(query: string): SearchItem[] {
    const q = query.trim().toLowerCase();
    if (!q) return [];
    return searchData.filter((item) => {
      return (
        item.title.toLowerCase().includes(q) ||
        item.description.toLowerCase().includes(q) ||
        item.tags.some((tag) => tag.toLowerCase().includes(q))
      );
    });
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function renderResults(query: string, results: SearchItem[]) {
    const list = document.getElementById('search-modal-results');
    const status = document.getElementById('search-modal-status');
    if (!list || !status) return;

    if (!query.trim()) {
      list.innerHTML = '';
      status.innerHTML = '<span class="search-modal-hint">输入关键字搜索文章…匹配标题、描述、标签</span>';
      activeIndex = 0;
      return;
    }

    if (results.length === 0) {
      list.innerHTML = '';
      status.innerHTML = `<span class="search-modal-hint">没有找到与「${escapeHtml(query)}」相关的文章</span>`;
      activeIndex = 0;
      return;
    }

    status.innerHTML = `<span class="search-modal-hint">找到 ${results.length} 篇文章</span>`;

    list.innerHTML = results
      .map((item, idx) => {
        const cat = CATEGORY_LABELS[item.category] || item.category.toUpperCase();
        const tagStr = item.tags.slice(0, 3).map((t) => '#' + escapeHtml(t)).join(' ');
        return `
          <li class="search-result-item${idx === 0 ? ' is-active' : ''}" data-index="${idx}">
            <a href="${escapeHtml(item.url)}">
              <span class="search-result-title">${escapeHtml(item.title)}</span>
              <span class="search-result-desc">${escapeHtml(item.description)}</span>
              <span class="search-result-meta">${cat}${tagStr ? ' · ' + tagStr : ''}</span>
            </a>
          </li>
        `;
      })
      .join('');

    activeIndex = 0;
  }

  function setActiveItem(idx: number) {
    const items = document.querySelectorAll<HTMLElement>('.search-result-item');
    if (items.length === 0) return;
    const max = items.length - 1;
    activeIndex = Math.max(0, Math.min(max, idx));
    items.forEach((el, i) => {
      el.classList.toggle('is-active', i === activeIndex);
      if (i === activeIndex) {
        el.scrollIntoView({ block: 'nearest' });
      }
    });
  }

  function openSearchModal() {
    const modal = document.getElementById('search-modal');
    const input = document.getElementById('search-modal-input') as HTMLInputElement | null;
    if (!modal || !input) return;
    loadSearchData();
    modal.removeAttribute('hidden');
    requestAnimationFrame(() => {
      modal.classList.add('is-open');
      input.focus();
      input.select();
    });
    document.body.style.overflow = 'hidden';
  }

  function closeSearchModal() {
    const modal = document.getElementById('search-modal');
    if (!modal) return;
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    setTimeout(() => {
      modal.setAttribute('hidden', '');
    }, 250);
  }

  function isOpen(): boolean {
    const modal = document.getElementById('search-modal');
    return !!modal && modal.classList.contains('is-open');
  }

  // ---------- 初始化 ----------
  function init() {
    const input = document.getElementById('search-modal-input') as HTMLInputElement | null;
    const modal = document.getElementById('search-modal');
    if (!input || !modal) return;

    // 防抖输入
    let debounceTimer: number | undefined;
    input.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value;
      window.clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => {
        renderResults(query, search(query));
      }, 200);
    });

    // 键盘导航
    input.addEventListener('keydown', (e) => {
      const items = document.querySelectorAll<HTMLElement>('.search-result-item');
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActiveItem(activeIndex + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActiveItem(activeIndex - 1);
      } else if (e.key === 'Enter') {
        const active = items[activeIndex];
        const link = active?.querySelector('a');
        if (link) {
          window.location.href = (link as HTMLAnchorElement).href;
        }
      }
    });

    // 关闭交互
    modal.querySelectorAll('[data-search-close]').forEach((el) => {
      el.addEventListener('click', closeSearchModal);
    });

    // 全局触发
    document.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement).closest('[data-search-trigger]');
      if (target) {
        e.preventDefault();
        openSearchModal();
      }
    });

    // 全局快捷键
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && (e.key === 'k' || e.key === 'K')) {
        e.preventDefault();
        if (isOpen()) {
          closeSearchModal();
        } else {
          openSearchModal();
        }
      } else if (e.key === 'Escape' && isOpen()) {
        closeSearchModal();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
