---
import type { Post } from '@/utils/post';
import { SITE_CONFIG } from '@/config';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, pubDate, category, tags } = post.data;
const categoryConfig = SITE_CONFIG.categories[category];

// 与 LatestPosts.astro 相同的渐变占位算法,根据 slug 稳定上色
function gradientFor(slug: string, cat: string): string {
  let h1 = 0;
  for (let i = 0; i < slug.length; i++) h1 = (h1 * 31 + slug.charCodeAt(i)) | 0;
  const hue1 = Math.abs(h1) % 360;
  const hue2 = (hue1 + 60 + (Math.abs(h1) % 60)) % 360;
  const sat = cat === 'tech' ? 70 : cat === 'travel' ? 60 : 55;
  const lit = 26;
  return `linear-gradient(135deg, hsl(${hue1}, ${sat}%, ${lit}%) 0%, hsl(${hue2}, ${sat}%, ${lit + 8}%) 100%)`;
}

function asEnglishDate(d: Date): string {
  const months = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
  return `${months[d.getMonth()]} ${String(d.getDate()).padStart(2, '0')}`;
}

const dateLabel = asEnglishDate(new Date(pubDate));
const coverGradient = gradientFor(post.slug, category);
---

<article class="post-card" data-reveal>
  <a href={`/blog/${post.slug}`} class="post-card-link">
    <div class="post-card-meta">
      <time datetime={pubDate.toISOString()} class="post-card-date">{dateLabel}</time>
      <span class="post-card-cat">{categoryConfig.name.toUpperCase()}</span>
    </div>

    <div class="post-card-content">
      <h2 class="post-card-title">{title}</h2>
      <p class="post-card-desc">{description}</p>
      {tags && tags.length > 0 && (
        <div class="post-card-tags">
          {tags.slice(0, 4).map((tag) => (
            <span class="post-card-tag">#{tag}</span>
          ))}
        </div>
      )}
    </div>

    <div class="post-card-cover" style={`background: ${coverGradient};`} aria-hidden="true">
      <span class="post-card-cover-noise"></span>
      <span class="post-card-cover-cta">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </span>
    </div>
  </a>
</article>

<style>
  .post-card {
    border-bottom: 1px solid var(--color-border);
  }

  .post-card-link {
    display: grid;
    grid-template-columns: 110px 1fr 200px;
    gap: var(--spacing-lg);
    align-items: center;
    padding: 1.6rem 0;
    color: var(--color-text);
    text-decoration: none;
    border: none;
    transition: background-color var(--duration-fast) var(--ease-smooth),
                padding var(--duration-fast) var(--ease-smooth);
  }

  .post-card-link:hover {
    padding-left: var(--spacing-md);
    padding-right: var(--spacing-md);
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.03) 0%, transparent 95%);
  }

  /* ---------- 元信息 ---------- */
  .post-card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    align-self: start;
    padding-top: 0.4rem;
  }

  .post-card-date {
    color: var(--color-text);
    font-weight: 500;
  }

  .post-card-cat {
    color: var(--color-text-tertiary);
  }

  /* ---------- 正文 ---------- */
  .post-card-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .post-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.3;
    color: var(--color-text);
    margin: 0;
  }

  .post-card-desc {
    color: var(--color-text-secondary);
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.2rem;
  }

  .post-card-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.04em;
  }

  /* ---------- 封面占位 ---------- */
  .post-card-cover {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: transform var(--duration-base) var(--ease-smooth);
  }

  .post-card-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 30px rgba(0, 0, 0, 0.5);
    border-radius: inherit;
    pointer-events: none;
  }

  .post-card-link:hover .post-card-cover {
    transform: scale(1.02);
  }

  .post-card-cover-noise {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 30%, rgba(255, 255, 255, 0.4), transparent 50%),
      radial-gradient(1px 1px at 60% 70%, rgba(255, 255, 255, 0.3), transparent 50%),
      radial-gradient(1.5px 1.5px at 40% 80%, rgba(255, 255, 255, 0.35), transparent 50%),
      radial-gradient(1px 1px at 80% 20%, rgba(255, 255, 255, 0.25), transparent 50%);
    mix-blend-mode: overlay;
    opacity: 0.5;
  }

  .post-card-cover-cta {
    position: absolute;
    right: 12px;
    bottom: 10px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: var(--color-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color var(--duration-fast) var(--ease-smooth),
                transform var(--duration-fast) var(--ease-smooth);
  }

  .post-card-link:hover .post-card-cover-cta {
    background: var(--color-text);
    color: var(--color-bg);
    transform: translateX(3px);
  }

  /* ---------- 响应式 ---------- */
  @media (max-width: 960px) {
    .post-card-link {
      grid-template-columns: 90px 1fr;
      gap: var(--spacing-md);
    }

    .post-card-cover {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .post-card-link {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }

    .post-card-meta {
      flex-direction: row;
      gap: 0.4rem;
      padding-top: 0;
    }
  }
</style>
