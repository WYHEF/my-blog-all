---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/config';

const techStack = [
  { name: 'Python',     percent: 100, color: '#3572A5', desc: '主要开发语言,脚本与自动化' },
  { name: 'Java',       percent: 80,  color: '#b07219', desc: '熟悉 Java SE 与面向对象设计' },
  { name: 'JavaScript', percent: 70,  color: '#f1e05a', desc: '基本前端开发能力' },
  { name: 'Vue',        percent: 70,  color: '#41b883', desc: '熟悉 Vue 生态系统' },
  { name: 'SpringBoot', percent: 60,  color: '#6db33f', desc: '后端服务开发' },
  { name: 'HTML/CSS',   percent: 60,  color: '#e34c26', desc: '页面布局与样式' },
  { name: 'C++',        percent: 40,  color: '#f34b7d', desc: '算法学习' },
];
---

<BaseLayout
  title={`关于 - ${SITE_CONFIG.title}`}
  description={`关于 ${SITE_CONFIG.author}`}
>
  <div class="about-container">
    <header class="about-header">
      <span class="about-kicker">[ ABOUT ]</span>
      <h1 class="about-title">Hi, I'm yufan.</h1>
      <p class="about-lede">{SITE_CONFIG.author} · WYHEF · 五氧化二钒不是废钒</p>
    </header>

    <div class="about-content">
      <!-- 左侧 Profile -->
      <aside class="profile-card">
        <div class="avatar-wrapper">
          <img src={SITE_CONFIG.avatar} alt={SITE_CONFIG.author} class="avatar" />
          <span class="avatar-glow" aria-hidden="true"></span>
        </div>
        <div class="profile-info">
          <h2 class="profile-name">{SITE_CONFIG.author}</h2>
          <p class="profile-login">@WYHEF</p>
          <p class="profile-bio">记录技术、学习与生活。</p>

          <div class="social-links">
            <a href={SITE_CONFIG.github} target="_blank" rel="noopener noreferrer" class="social-link" title="GitHub">
              <svg class="icon" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
              <span>GitHub</span>
            </a>
            <a href={SITE_CONFIG.bilibili} target="_blank" rel="noopener noreferrer" class="social-link" title="Bilibili">
              <svg class="icon" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="13" rx="2"></rect><path d="M17 2l-5 5-5-5"></path></svg>
              <span>Bilibili</span>
            </a>
            <a href={`mailto:${SITE_CONFIG.email}`} class="social-link" title="Email">
              <svg class="icon" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              <span>{SITE_CONFIG.email}</span>
            </a>

            <div class="social-link wechat-trigger" tabindex="0" title="微信扫码关注">
              <svg class="icon" viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 13.5l-1.5 2.5v-2.5h-1c-2.5 0-4.5-2-4.5-4.5s2-4.5 4.5-4.5 4.5 2 4.5 4.5c0 1-.5 2-1.5 3z"></path><path d="M17.5 12c-2.5 0-4.5 2-4.5 4.5s2 4.5 4.5 4.5c1 0 2-.5 2.5-1v1h2.5l-1.5-2.5c1-1 1.5-2 1.5-3 0-2.5-2-4.5-4.5-4.5z"></path></svg>
              <span>{SITE_CONFIG.wechat}</span>

              <div class="qr-popup" role="tooltip">
                <img src="/qrcode.jpg" alt="微信公众号二维码" class="qr-img" />
                <span class="qr-tip">扫码关注</span>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- 右侧 Content -->
      <article class="bio-text">
        <section class="intro-section">
          <h2>你好,我是吴煜凡。</h2>
          <p>
            欢迎来到我的个人博客。我是一名热衷于计算机技术的开发者和学习者,ID 是 <strong>WYHEF</strong>(也就是五氧化二钒的缩写)。
          </p>
          <p>
            我热衷于探索代码背后的逻辑,同时也享受构建工具来解决实际问题的过程。目前主要关注后端开发、脚本自动化以及 Web 全栈技术。
          </p>
        </section>

        <section>
          <h3>关于本站</h3>
          <p>
            建立这个博客的初衷是为了构建一个属于自己的知识库。在这个信息碎片化的时代,我希望通过长文写作来沉淀思考,记录学习过程中的灵光一现。
          </p>
          <p>在这里,你主要会看到以下内容:</p>
          <ul class="status-list">
            <li><strong>技术笔记</strong> — 关于 Python、Java、SpringBoot 等技术的学习心得与踩坑记录。</li>
            <li><strong>项目实战</strong> — 个人项目的开发过程复盘与技术总结。</li>
            <li><strong>算法与逻辑</strong> — 在 C++ 算法学习过程中的思考。</li>
            <li><strong>生活随笔</strong> — 关于旅行、阅读和生活的些许感悟。</li>
          </ul>
        </section>

        <section>
          <h3>技术栈</h3>
          <p>下面是我目前主要使用的技术工具与熟练度:</p>

          <div class="tech-stack">
            {techStack.map((tech) => (
              <div class="tech-item">
                <div class="tech-header">
                  <span class="tech-name">{tech.name}</span>
                  <span class="tech-desc">{tech.desc}</span>
                  <span class="tech-percent">{tech.percent}</span>
                </div>
                <div class="progress-bar">
                  <div
                    class="progress-fill"
                    style={`width: ${tech.percent}%; --bar-color: ${tech.color};`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section>
          <h3>联系</h3>
          <p>
            如果你对我的文章感兴趣,或者有技术问题想要交流,欢迎通过左侧的社交链接联系我。
            你也可以关注我的微信公众号 <strong>"五氧化二钒不是废钒"</strong>,获取更多动态。
          </p>
        </section>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .about-container {
    max-width: 1080px;
    margin: 0;
    padding-right: var(--spacing-lg);
  }

  /* ---------- 头部 ---------- */
  .about-header {
    padding: var(--spacing-xl) 0 var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .about-kicker {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.18em;
    margin-bottom: var(--spacing-sm);
  }

  .about-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.6rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-text);
    margin: 0 0 var(--spacing-sm);
  }

  .about-lede {
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .about-content {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--spacing-xl);
    align-items: start;
  }

  /* ---------- Profile 卡片 ---------- */
  .profile-card {
    position: sticky;
    top: calc(var(--header-height) + 24px);
  }

  .avatar-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-md);
    border: 1px solid var(--color-border);
    background-color: rgba(255, 255, 255, 0.03);
    isolation: isolate;
  }

  .avatar-glow {
    position: absolute;
    inset: -30%;
    background: radial-gradient(circle at 70% 30%, rgba(120, 170, 255, 0.35), transparent 60%);
    filter: blur(50px);
    z-index: -1;
    pointer-events: none;
  }

  .avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 500;
    margin: 0;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .profile-login {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.05em;
    margin: 0.2rem 0 var(--spacing-sm);
  }

  .profile-bio {
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 var(--spacing-md);
    color: var(--color-text-secondary);
  }

  /* ---------- 社交链接 ---------- */
  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    border-top: 1px solid var(--color-border);
    padding-top: var(--spacing-md);
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-text-secondary);
    font-size: 0.88rem;
    text-decoration: none;
    cursor: pointer;
    position: relative;
    padding: 0.4rem 0.5rem;
    border-radius: var(--radius-sm);
    border: none;
    transition: color var(--duration-fast) var(--ease-smooth),
                background-color var(--duration-fast) var(--ease-smooth);
  }

  .social-link:hover {
    color: var(--color-text);
    background-color: rgba(255, 255, 255, 0.04);
  }

  .icon {
    flex-shrink: 0;
    color: currentColor;
  }

  /* ---------- 微信二维码 ---------- */
  .wechat-trigger:hover .qr-popup,
  .wechat-trigger:focus-visible .qr-popup {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .qr-popup {
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border-strong);
    padding: 12px;
    border-radius: var(--radius-md);
    box-shadow: 0 20px 60px -10px rgba(0, 0, 0, 0.8),
                0 0 0 1px rgba(255, 255, 255, 0.04);
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 100;
    width: 160px;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-fast) var(--ease-smooth),
                transform var(--duration-fast) var(--ease-smooth);
  }

  .qr-img {
    width: 136px;
    height: 136px;
    object-fit: contain;
    margin-bottom: 6px;
    background-color: #ffffff;
    border-radius: var(--radius-sm);
  }

  .qr-tip {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.12em;
  }

  /* ---------- Bio 文本 ---------- */
  .bio-text {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .bio-text h2 {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin: 0 0 var(--spacing-md);
  }

  .bio-text h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--color-text);
    margin: var(--spacing-xl) 0 var(--spacing-md);
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
    letter-spacing: -0.01em;
  }

  .bio-text p {
    margin-bottom: 1.4em;
    color: var(--color-text-secondary);
  }

  .bio-text strong {
    color: var(--color-text);
    font-weight: 600;
  }

  /* ---------- 列表 ---------- */
  .status-list {
    list-style-type: none;
    margin: 0 0 1.5em 0;
    padding: 0;
  }

  .status-list li {
    margin-bottom: 0.6rem;
    padding-left: 1.4rem;
    position: relative;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  .status-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 8px;
    height: 1px;
    background-color: var(--color-text);
  }

  /* ---------- 技术栈进度条 ---------- */
  .tech-stack {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin: var(--spacing-md) 0 var(--spacing-lg);
  }

  .tech-header {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    margin-bottom: 0.5rem;
    font-size: 0.88rem;
  }

  .tech-name {
    font-family: var(--font-mono);
    color: var(--color-text);
    font-weight: 500;
    flex-shrink: 0;
    min-width: 92px;
  }

  .tech-desc {
    color: var(--color-text-tertiary);
    font-size: 0.82rem;
    flex: 1;
  }

  .tech-percent {
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
  }

  .progress-bar {
    width: 100%;
    height: 4px;
    background-color: rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    border-radius: 2px;
    background-color: var(--bar-color, var(--color-text));
    box-shadow: 0 0 12px var(--bar-color, transparent);
    opacity: 0.85;
    transition: width 0.8s var(--ease-smooth);
  }

  /* ---------- 响应式 ---------- */
  @media (max-width: 900px) {
    .about-content {
      grid-template-columns: 1fr;
    }

    .profile-card {
      position: static;
      margin-bottom: var(--spacing-xl);
      padding-bottom: var(--spacing-lg);
      border-bottom: 1px solid var(--color-border);
    }

    .avatar-wrapper {
      max-width: 200px;
    }

    .about-container {
      padding-right: 0;
    }

    .qr-popup {
      left: 0;
      transform: translateY(8px);
    }

    .wechat-trigger:hover .qr-popup,
    .wechat-trigger:focus-visible .qr-popup {
      transform: translateY(0);
    }
  }
</style>
