---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Pagination from '@components/Pagination.astro';
import { formatDate, getAdjacentPosts } from '@/utils/post';
import { SITE_CONFIG } from '@/config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const { title, description, pubDate, updatedDate, category, tags, cover } = post.data;
const categoryConfig = SITE_CONFIG.categories[category];

const { prev, next } = await getAdjacentPosts(post.slug);
---

<BaseLayout
  title={title}
  description={description}
  image={cover}
  article={true}
  publishedTime={pubDate}
  tags={tags}
  currentSlug={post.slug}
  currentCategory={category}
  headings={headings}
>
  <div class="article-container">
    <article class="post">
      <header class="post-header">
        <div class="post-meta">
          <a href={`/category/${category}`} class="category-tag">
            {categoryConfig.name.toUpperCase()}
          </a>
          <span class="meta-sep">·</span>
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        </div>

        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>

        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <a href={`/tags/${tag}`} class="tag">#{tag}</a>
            ))}
          </div>
        )}

        {cover && (
          <img src={cover} alt={title} class="post-cover">
        )}
      </header>

      <div class="post-content">
        <Content />

        {updatedDate && (
          <div class="post-updated">
            最后更新：{formatDate(updatedDate)}
          </div>
        )}
      </div>

      <Pagination
        prev={prev ? { title: prev.data.title, url: `/blog/${prev.slug}` } : undefined}
        next={next ? { title: next.data.title, url: `/blog/${next.slug}` } : undefined}
      />
    </article>
  </div>
</BaseLayout>

<style>
  .article-container {
    max-width: 820px;
    margin: 0;
    width: 100%;
  }

  .post {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* ---------- 头部 ---------- */
  .post-header {
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin-bottom: var(--spacing-md);
  }

  .meta-sep {
    color: var(--color-text-tertiary);
  }

  .category-tag {
    color: var(--color-text);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-pill);
    padding: 0.2rem 0.6rem;
    font-weight: 500;
    transition: background-color var(--duration-fast) var(--ease-smooth),
                color var(--duration-fast) var(--ease-smooth);
  }

  .category-tag:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 var(--spacing-md);
  }

  .post-description {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: var(--spacing-lg);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--spacing-md);
  }

  .tag {
    color: var(--color-text-secondary);
    font-size: 0.78rem;
    font-family: var(--font-mono);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-sm);
    border-bottom: 1px solid var(--color-border);
    transition: border-color var(--duration-fast) var(--ease-smooth),
                color var(--duration-fast) var(--ease-smooth);
  }

  .tag:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
  }

  .post-cover {
    width: 100%;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    border-radius: var(--radius-md);
    margin-top: var(--spacing-lg);
    border: 1px solid var(--color-border);
  }

  /* ---------- 正文 ---------- */
  .post-content {
    line-height: 1.8;
    color: var(--color-text);
  }

  .post-content :global(h2) {
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    padding-top: var(--spacing-md);
    border-bottom: none;
    font-family: var(--font-display);
    font-size: 1.85rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .post-content :global(h3) {
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .post-content :global(h4) {
    margin-top: var(--spacing-md);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .post-content :global(p) {
    margin-bottom: 1.4em;
    color: var(--color-text);
  }

  .post-content :global(a) {
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border-strong);
    transition: border-color var(--duration-fast) var(--ease-smooth);
  }

  .post-content :global(a:hover) {
    border-bottom-color: var(--color-text);
  }

  .post-content :global(img) {
    margin: var(--spacing-lg) 0;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    width: 100%;
  }

  .post-content :global(blockquote) {
    border-left: 2px solid var(--color-border-strong);
    padding-left: var(--spacing-md);
    margin: var(--spacing-lg) 0;
    color: var(--color-text-secondary);
    background-color: transparent;
  }

  .post-content :global(pre) {
    background-color: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .post-content :global(code) {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.4em;
    font-size: 0.88em;
    color: var(--color-text);
  }

  .post-content :global(pre code) {
    background-color: transparent;
    border: none;
    padding: 0;
    color: inherit;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--spacing-xl) 0;
  }

  /* ---------- 末尾 ---------- */
  .post-updated {
    margin-top: var(--spacing-xl);
    padding: var(--spacing-md);
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 0.82rem;
    color: var(--color-text-tertiary);
    text-align: left;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: clamp(1.6rem, 7vw, 2.2rem);
    }

    .post-description {
      font-size: 1rem;
    }
  }
</style>
