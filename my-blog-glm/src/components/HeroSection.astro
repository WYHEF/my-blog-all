---
import Search from './Search.astro';
import { getAllPosts, getAllTags } from '@/utils/post';
import { SITE_CONFIG } from '@/config';

interface Props {
  title?: string;
  subtitle?: string;
}

const { title = SITE_CONFIG.title, subtitle = SITE_CONFIG.description } = Astro.props;

const posts = await getAllPosts();
const tags = await getAllTags();
const postCount = posts.length;
const tagCount = tags.length;
const categoryCount = Object.keys(SITE_CONFIG.categories).length;
---

<section class="hero" id="hero">
  <!-- 动画背景层 -->
  <div class="hero-bg" aria-hidden="true">
    <div class="glow-orb glow-orb-1"></div>
    <div class="glow-orb glow-orb-2"></div>
    <div class="glow-orb glow-orb-3"></div>
    <canvas id="hero-canvas" class="hero-particles"></canvas>
  </div>

  <!-- 内容层 - 使用 :global() 确保 scoped 下文字可见 -->
  <div class="hero-content">
    <h1 class="hero-title">
      <span class="title-prefix">Welcome to</span>
      <span class="title-main">{title}</span>
    </h1>

    <p class="hero-subtitle">{subtitle}</p>

    <div class="hero-search">
      <Search />
    </div>

    <div class="hero-stats">
      <span class="stat-item">{postCount} 篇文章</span>
      <span class="stat-separator">·</span>
      <span class="stat-item">{tagCount} 个标签</span>
      <span class="stat-separator">·</span>
      <span class="stat-item">{categoryCount} 个分类</span>
    </div>
  </div>

  <!-- 滚动指示器 -->
  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-line"></div>
  </div>
</section>

<!-- 粒子动画脚本 -->
<script is:inline>
(function() {
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (!canvas) return;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  let width = 0;
  let height = 0;
  let particles: Array<{
    x: number; y: number; size: number;
    opacity: number; speedX: number; speedY: number;
    twinkleSpeed: number; twinklePhase: number;
  }> = [];

  function resize() {
    width = canvas.width = canvas.offsetWidth * (window.devicePixelRatio || 1);
    height = canvas.height = canvas.offsetHeight * (window.devicePixelRatio || 1);
    ctx.scale(window.devicePixelRatio || 1, window.devicePixelRatio || 1);
    initParticles();
  }

  function initParticles() {
    particles = [];
    const count = Math.min(Math.floor((width * height) / 15000), 80);
    for (let i = 0; i < count; i++) {
      particles.push({
        x: Math.random() * (width / (window.devicePixelRatio || 1)),
        y: Math.random() * (height / (window.devicePixelRatio || 1)),
        size: Math.random() * 1.5 + 0.5,
        opacity: Math.random() * 0.6 + 0.2,
        speedX: (Math.random() - 0.5) * 0.15,
        speedY: (Math.random() - 0.5) * 0.15,
        twinkleSpeed: Math.random() * 0.02 + 0.005,
        twinklePhase: Math.random() * Math.PI * 2
      });
    }
  }

  function animate() {
    const w = width / (window.devicePixelRatio || 1);
    const h = height / (window.devicePixelRatio || 1);

    ctx.clearRect(0, 0, w, h);

    particles.forEach(p => {
      p.x += p.speedX;
      p.y += p.speedY;
      if (p.x < 0) p.x = w;
      if (p.x > w) p.x = 0;
      if (p.y < 0) p.y = h;
      if (p.y > h) p.y = 0;

      p.twinklePhase += p.twinkleSpeed;
      const twinkle = 0.5 + 0.5 * Math.sin(p.twinklePhase);
      const alpha = p.opacity * twinkle;

      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(200, 200, 255, ${alpha})`;
      ctx.fill();

      if (p.size > 1.2) {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size * 3, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(124, 58, 237, ${alpha * 0.08})`;
        ctx.fill();
      }
    });

    requestAnimationFrame(animate);
  }

  resize();
  window.addEventListener('resize', resize);
  animate();
})();
</script>

<style>
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: var(--spacing-3xl) var(--spacing-lg);
  }

  /* === 动画背景层 === */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .glow-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    animation: float 8s ease-in-out infinite;
    will-change: transform;
  }

  .glow-orb-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.18) 0%, transparent 70%);
    top: -10%;
    left: -5%;
  }

  .glow-orb-2 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.12) 0%, transparent 70%);
    bottom: -15%;
    right: -10%;
    animation-delay: -3s;
    animation-duration: 10s;
  }

  .glow-orb-3 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.1) 0%, transparent 70%);
    top: 40%;
    left: 50%;
    transform: translateX(-50%);
    animation-delay: -5s;
    animation-duration: 12s;
  }

  .hero-particles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  /* === 内容层 - 关键：高 z-index + 显式颜色 === */
  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 700px;
    width: 100%;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.08;
    margin-bottom: var(--spacing-md);
    color: #ffffff;
  }

  .title-prefix {
    display: block;
    font-size: 0.35em;
    font-weight: 600;
    color: #888888;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.3em;
  }

  .title-main {
    display: block;
    background: linear-gradient(135deg, #7c3aed 0%, #3b82f6 50%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: #a0a0a0;
    max-width: 520px;
    margin: 0 auto var(--spacing-lg);
    line-height: 1.6;
  }

  .hero-search {
    max-width: 560px;
    margin: 0 auto;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: var(--spacing-xl);
    font-size: 0.85rem;
    color: #888888;
    font-family: var(--font-mono);
  }

  .stat-separator {
    opacity: 0.4;
  }

  /* === 滚动指示器 === */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, #7c3aed, transparent);
    animation: pulseGlow 2s ease-in-out infinite;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 70vh;
      padding: var(--spacing-2xl) var(--spacing-md);
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .hero-stats {
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .scroll-indicator {
      bottom: 1.5rem;
    }
  }
</style>
