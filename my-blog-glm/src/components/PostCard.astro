---
import type { Post } from '@/utils/post';
import { formatDate, getCategoryGradient } from '@/utils/post';
import { SITE_CONFIG } from '@/config';

interface Props {
  post: Post;
  coverImage?: string | null;
}

const { post, coverImage } = Astro.props;
const { title, description, pubDate, category, tags } = post.data;
const categoryConfig = SITE_CONFIG.categories[category];
---

<article class="post-card glow-card animate-fade-up">
  <a href={`/blog/${post.slug}`} class="post-card-link">
    <div class="post-card-body">
      <!-- 左侧：文字内容 -->
      <div class="post-card-text">
        <div class="post-card-meta">
          <span class="post-category">{categoryConfig.displayName}</span>
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        </div>

        <h2 class="post-card-title">{title}</h2>

        <p class="post-card-description">{description}</p>

        {tags && tags.length > 0 && (
          <div class="post-card-tags">
            {tags.slice(0, 3).map(tag => (
              <span class="post-tag">#{tag}</span>
            ))}
          </div>
        )}
      </div>

      <!-- 右侧：封面图 -->
      <div class="post-card-image">
        {coverImage ? (
          <img src={coverImage} alt={title} loading="lazy" />
        ) : (
          <div class="post-card-placeholder" style={`background: ${getCategoryGradient(category)}`}>
            <span class="placeholder-icon">{categoryConfig.displayName.charAt(0)}</span>
          </div>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    display: block;
  }

  .post-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border: none;
  }

  .post-card-body {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: var(--spacing-lg);
    align-items: center;
    padding: 0; /* padding 由 GlowCard 提供 */
  }

  /* ====== 左侧文字区 ====== */
  .post-card-text {
    min-width: 0;
    padding: var(--spacing-lg);
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-sm);
  }

  .post-category {
    color: var(--color-accent-light);
    font-weight: 600;
  }

  .post-card-title {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: var(--spacing-xs);
    color: var(--color-text-primary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--transition-fast);
  }

  .post-card:hover .post-card-title {
    color: var(--color-accent-light);
  }

  .post-card-description {
    font-size: 0.92rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: var(--spacing-sm);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: overflow;
  }

  .post-card-tags {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .post-tag {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    padding: 0.18rem 0.5rem;
    background: rgba(255, 255, 255, 0.04);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .post-card:hover .post-tag {
    color: var(--color-text-secondary);
    background: rgba(255, 255, 255, 0.07);
  }

  /* ====== 右侧图片区 ====== */
  .post-card-image {
    width: 260px;
    height: 170px;
    border-radius: var(--radius-md);
    overflow: hidden;
    flex-shrink: 0;
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .post-card:hover .post-card-image img {
    transform: scale(1.06);
  }

  /* 无图时的渐变占位块 */
  .post-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-md);
  }

  /* ====== 移动端响应式 ====== */
  @media (max-width: 768px) {
    .post-card-body {
      grid-template-columns: 1fr;
    }

    .post-card-image {
      width: 100%;
      height: 200px;
      order: -1; /* 图片置顶 */
    }

    .post-card-text {
      padding: var(--spacing-md) var(--spacing-md) var(--spacing-lg);
    }

    .post-card-title {
      font-size: 1.2rem;
    }
  }
</style>
