---
/**
 * ConstellationDivider - 星座分隔符组件
 * 用于首页各 section 之间的视觉分隔装饰
 * SVG 节点连线图案 + 微妙脉动动画
 */
---

<div class="constellation-divider" aria-hidden="true">
  <svg class="constellation-svg" viewBox="0 0 1200 200" preserveAspectRatio="xMidYMid meet">
    <!-- 连线 -->
    <g class="constellation-lines" stroke="rgba(124, 58, 237, 0.15)" stroke-width="1" fill="none">
      <line x1="100" y1="100" x2="280" y2="50"/>
      <line x1="280" y1="50" x2="450" y2="120"/>
      <line x1="450" y1="120" x2="600" y2="60"/>
      <line x1="600" y1="60" x2="750" y2="140"/>
      <line x1="750" y1="140" x2="920" y2="70"/>
      <line x1="920" y1="70" x2="1100" y2="100"/>

      <!-- 次级连线 -->
      <line x1="280" y1="50" x2="380" y2="150" stroke-opacity="0.07"/>
      <line x1="450" y1="120" x2="550" y2="170" stroke-opacity="0.07"/>
      <line x1="600" y1="60" x2="500" y2="30" stroke-opacity="0.07"/>
      <line x1="750" y1="140" x2="850" y2="180" stroke-opacity="0.07"/>
      <line x1="920" y1="70" x2="1020" y2="160" stroke-opacity="0.07"/>
    </g>

    <!-- 节点 -->
    <g class="constellation-nodes">
      <circle cx="100" cy="100" r="3" class="node node-1"/>
      <circle cx="280" cy="50" r="4" class="node node-2"/>
      <circle cx="450" cy="120" r="3" class="node node-3"/>
      <circle cx="600" cy="60" r="5" class="node node-4"/>
      <circle cx="750" cy="140" r="3" class="node node-5"/>
      <circle cx="920" cy="70" r="4" class="node node-6"/>
      <circle cx="1100" cy="100" r="3" class="node node-7"/>

      <!-- 次级节点 -->
      <circle cx="380" cy="150" r="2" class="node-secondary"/>
      <circle cx="550" cy="170" r="2" class="node-secondary"/>
      <circle cx="500" cy="30" r="2" class="node-secondary"/>
      <circle cx="850" cy="180" r="2" class="node-secondary"/>
      <circle cx="1020" cy="160" r="2" class="node-secondary"/>
    </g>
  </svg>
</div>

<style>
  .constellation-divider {
    width: 100%;
    padding: var(--spacing-xl) 0;
    display: flex;
    justify-content: center;
    overflow: hidden;
  }

  .constellation-svg {
    width: 100%;
    max-width: 1000px;
    height: auto;
  }

  /* 主节点样式 */
  .node {
    fill: rgba(200, 200, 255, 0.6);
    filter: drop-shadow(0 0 4px rgba(124, 58, 237, 0.4));
  }

  /* 次级节点 */
  .node-secondary {
    fill: rgba(150, 150, 200, 0.3);
  }

  /* 节点脉动动画 - 错开延迟 */
  .node-1 { animation: pulseNode 3s ease-in-out infinite; }
  .node-2 { animation: pulseNode 3s ease-in-out infinite 0.5s; }
  .node-3 { animation: pulseNode 3s ease-in-out infinite 1s; }
  .node-4 { animation: pulseNode 3s ease-in-out infinite 1.5s; }
  .node-5 { animation: pulseNode 3s ease-in-out infinite 2s; }
  .node-6 { animation: pulseNode 3s ease-in-out infinite 2.5s; }
  .node-7 { animation: pulseNode 3s ease-in-out infinite 0.8s; }

  @keyframes pulseNode {
    0%, 100% {
      opacity: 0.5;
      r: 3;
    }
    50% {
      opacity: 1;
      r: 5;
    }
  }

  /* 连线微弱流动效果 */
  .constellation-lines line {
    animation: flowLine 4s ease-in-out infinite;
  }

  .constellation-lines line:nth-child(odd) {
    animation-direction: reverse;
    animation-duration: 5s;
  }

  @keyframes flowLine {
    0%, 100% { stroke-opacity: 0.1; }
    50% { stroke-opacity: 0.25; }
  }

  @media (prefers-reduced-motion: reduce) {
    .node, .constellation-lines line {
      animation: none !important;
    }
  }
</style>
