---
import { SITE_CONFIG } from '@/config';

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <!-- 列1: 品牌 -->
    <div class="footer-brand">
      <div class="footer-logo">{SITE_CONFIG.title}</div>
      <p class="footer-tagline">{SITE_CONFIG.description}</p>
      <div class="footer-social">
        <a href={SITE_CONFIG.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href={`mailto:${SITE_CONFIG.email}`} aria-label="Email">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </a>
        <a href={SITE_CONFIG.bilibili} target="_blank" rel="noopener noreferrer" aria-label="Bilibili">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.906l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.249.249.373.56.373.92s-.124.671-.373.92c-.249.249-.56.373-.933.373s-.684-.124-.933-.373a1.27 1.27 0 0 1-.373-.92c0-.36.124-.671.373-.92.249-.249.56-.373.933-.373zm8 0c.373 0 .684.124.933.373.249.249.373.56.373.92s-.124.671-.373.92c-.249.249-.56.373-.933.373s-.684-.124-.933-.373a1.27 1.27 0 0 1-.373-.92c0-.36.124-.671.373-.92.249-.249.56-.373.933-.373z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- 列2: 导航 -->
    <div class="footer-nav">
      <h4 class="footer-heading">导航</h4>
      <ul class="footer-links">
        {SITE_CONFIG.navLinks.map(link => (
          <li><a href={link.path}>{link.name}</a></li>
        ))}
      </ul>
    </div>

    <!-- 列3: 分类 -->
    <div class="footer-categories">
      <h4 class="footer-heading">分类</h4>
      <ul class="footer-links">
        {Object.entries(SITE_CONFIG.categories).map(([key, cat]) => (
          <li><a href={`/category/${key}`}>{cat.displayName}</a></li>
        ))}
      </ul>
    </div>

    <!-- 列4: 联系方式 -->
    <div class="footer-connect">
      <h4 class="footer-heading">联系方式</h4>
      <ul class="footer-links">
        <li><a href={SITE_CONFIG.github}>GitHub</a></li>
        <li><a href={SITE_CONFIG.bilibili}>Bilibili</a></li>
        <li><a href={`mailto:${SITE_CONFIG.email}`}>Email</a></li>
        <li><a href="/rss.xml">RSS Feed</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {currentYear} {SITE_CONFIG.author}. Built with Astro.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--spacing-2xl) var(--spacing-lg) var(--spacing-lg);
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--spacing-xl);
  }

  /* 品牌 */
  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-sm);
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--spacing-md);
    max-width: 280px;
  }

  .footer-social {
    display: flex;
    gap: var(--spacing-sm);
  }

  .footer-social a {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    border: none;
  }

  .footer-social a:hover {
    color: var(--color-accent-light);
  }

  /* 列标题 */
  .footer-heading {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-md);
  }

  /* 链接列表 */
  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-links a {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    border: none;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-text-primary);
  }

  /* 底部版权栏 */
  .footer-bottom {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--spacing-md) var(--spacing-lg);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* 响应式 */
  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-lg);
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 560px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }
</style>
