---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import { getPostsByCategory, extractFirstImage } from '@/utils/post';
import { SITE_CONFIG, type Category } from '@/config';

export async function getStaticPaths() {
  const categories = Object.keys(SITE_CONFIG.categories) as Category[];

  return Promise.all(
    categories.map(async (category) => {
      const posts = await getPostsByCategory(category);
      return {
        params: { category },
        props: { posts, category }
      };
    })
  );
}

const { posts, category } = Astro.props;
const categoryConfig = SITE_CONFIG.categories[category as Category];

// 提取封面图
const postsWithCovers = posts.map(post => ({
  post,
  coverImage: extractFirstImage(post.body ?? '')
}));
---

<BaseLayout
  title={`${categoryConfig.displayName} - ${SITE_CONFIG.title}`}
  description={categoryConfig.description}
>
  <div class="content-wrapper">
    <header class="category-header animate-fade-up">
      <span class="category-badge">{categoryConfig.displayName}</span>
      <h1 class="category-title">{categoryConfig.description}</h1>
      <p class="category-count">{posts.length} 篇文章</p>
    </header>

    <div class="posts-list" data-stagger>
      {postsWithCovers.map(({ post, coverImage }) => (
        <PostCard post={post} coverImage={coverImage} />
      ))}
    </div>

    {posts.length === 0 && (
      <div class="empty-state animate-fade-up">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/>
        </svg>
        <p>该分类下暂无文章</p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .category-header {
    padding: var(--spacing-2xl) 0 var(--spacing-xl);
    text-align: center;
  }

  .category-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-light);
    background: rgba(124, 58, 237, 0.12);
    padding: 0.3em 1em;
    border-radius: var(--radius-sm);
    margin-bottom: var(--spacing-md);
  }

  .category-title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-primary);
  }

  .category-count {
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    padding-bottom: var(--spacing-xl);
  }

  .empty-state {
    text-align: center;
    padding: var(--spacing-3xl) var(--spacing-lg);
    color: var(--color-text-muted);
  }

  .empty-state svg {
    margin: 0 auto var(--spacing-md);
    opacity: 0.4;
  }

  .empty-state p {
    font-size: 1rem;
  }
</style>
