---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面未找到">
  <div class="error-page">
    <!-- 背景装饰 -->
    <div class="error-bg">
      <div class="glow-orb error-orb"></div>
    </div>

    <div class="error-content">
      <h1 class="error-code gradient-text">404</h1>
      <h2 class="error-title">页面未找到</h2>
      <p class="error-description">
        抱歉，您访问的页面不存在或已被移除到宇宙深处。
      </p>
      <div class="error-actions">
        <a href="/" class="btn btn-primary">返回首页</a>
        <a href="/blog" class="btn btn-secondary">浏览文章</a>
      </div>
    </div>

    <div class="error-illustration">
      <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <circle cx="100" cy="100" r="80" fill="var(--color-surface)" stroke="var(--color-border)" stroke-width="1"/>
        <circle cx="75" cy="85" r="8" fill="var(--color-text-secondary)"/>
        <circle cx="125" cy="85" r="8" fill="var(--color-text-secondary)"/>
        <path d="M 65 125 Q 100 105 135 125" stroke="var(--color-text-secondary)" stroke-width="3" fill="none" stroke-linecap="round"/>
      </svg>
    </div>
  </div>
</BaseLayout>

<style>
  .error-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    padding: var(--spacing-xl) var(--spacing-lg);
    position: relative;
  }

  .error-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .error-orb {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.1) 0%, transparent 70%);
    filter: blur(60px);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: float 8s ease-in-out infinite;
  }

  .error-content {
    position: relative;
    z-index: 1;
    max-width: 480px;
    margin-bottom: var(--spacing-xl);
  }

  .error-code {
    font-size: clamp(5rem, 12vw, 8rem);
    font-weight: 800;
    margin-bottom: var(--spacing-md);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .error-title {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-primary);
  }

  .error-description {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-xl);
    line-height: 1.6;
  }

  .error-actions {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 1.75rem;
    border-radius: var(--btn-radius);
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
    border: none;
    transition: all var(--transition-normal);
  }

  .btn-primary {
    background: var(--gradient-accent);
    color: white;
    box-shadow: 0 4px 16px rgba(124, 58, 237, 0.25);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(124, 58, 237, 0.35);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-hover);
    background: rgba(255, 255, 255, 0.03);
  }

  .error-illustration {
    position: relative;
    z-index: 1;
    width: 180px;
    opacity: 0.4;
  }

  @media (max-width: 768px) {
    .error-code {
      font-size: 4.5rem;
    }

    .error-title {
      font-size: 1.4rem;
    }

    .error-actions {
      flex-direction: column;
      width: 100%;
      max-width: 280px;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
