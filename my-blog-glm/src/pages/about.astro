---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/config';

const techStack = [
  { name: 'Python', percent: 100, color: '#3572A5', desc: '主要开发语言，用于脚本与自动化' },
  { name: 'Java', percent: 80, color: '#b07219', desc: '熟悉 Java SE 及面向对象设计' },
  { name: 'JavaScript', percent: 70, color: '#f1e05a', desc: '能够进行基本的前端开发' },
  { name: 'Vue', percent: 70, color: '#41b883', desc: '熟悉 Vue 生态系统' },
  { name: 'SpringBoot', percent: 60, color: '#6db33f', desc: '具备后端服务开发能力' },
  { name: 'HTML/CSS', percent: 60, color: '#e34c26', desc: '页面布局与样式调整' },
  { name: 'C++', percent: 40, color: '#f34b7d', desc: '算法学习与底层逻辑探索' },
];
---

<BaseLayout
  title={`关于 - ${SITE_CONFIG.title}`}
  description={`关于 ${SITE_CONFIG.author}`}
>
  <div class="content-wrapper">
    <div class="about-container animate-fade-up">
      <!-- Profile 卡片 -->
      <aside class="profile-card glow-card">
        <div class="avatar-ring">
          <img src={SITE_CONFIG.avatar} alt={SITE_CONFIG.author} class="avatar">
        </div>
        <div class="profile-info">
          <h1 class="profile-name">{SITE_CONFIG.author}</h1>
          <p class="profile-login">WYHEF</p>
          <p class="profile-bio">记录技术、学习与生活。</p>

          <div class="social-links">
            <a href={SITE_CONFIG.github} target="_blank" rel="noopener noreferrer" class="social-link" title="GitHub">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
            <a href={SITE_CONFIG.bilibili} target="_blank" rel="noopener noreferrer" class="social-link" title="Bilibili">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.906l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.249.249.373.56.373.92s-.124.671-.373.92c-.249.249-.56.373-.933.373s-.684-.124-.933-.373a1.27 1.27 0 0 1-.373-.92c0-.36.124-.671.373-.92.249-.249.56-.373.933-.373zm8 0c.373 0 .684.124.933.373.249.249.373.56.373.92s-.124.671-.373.92c-.249.249-.56.373-.933.373s-.684-.124-.933-.373a1.27 1.27 0 0 1-.373-.92c0-.36.124-.671.373-.92.249-.249.56-.373.933-.373z"/></svg>
              Bilibili
            </a>
            <a href={`mailto:${SITE_CONFIG.email}`} class="social-link" title="Email">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>

            <!-- 微信二维码 -->
            <div class="social-link wechat-trigger" title="微信扫码关注">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.5 13.5l-1.5 2.5v-2.5h-1c-2.5 0-4.5-2-4.5-4.5s2-4.5 4.5-4.5 4.5 2 4.5 4.5c0 1-.5 2-1.5 3z"/><path d="M17.5 12c-2.5 0-4.5 2-4.5 4.5s2 4.5 4.5 4.5c1 0 2-.5 2.5-1v1h2.5l-1.5-2.5c1-1 1.5-2 1.5-3 0-2.5-2-4.5-4.5-4.5z"/></svg>

              <div class="qr-popup">
                <img src="/qrcode.jpg" alt="微信二维码" class="qr-img">
                <span class="qr-tip">{SITE_CONFIG.wechat}</span>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- 右侧内容 -->
      <article class="bio-text">
        <section class="intro-section">
          <h2>你好，我是吴煜凡。</h2>
          <p>欢迎来到我的个人博客。我是一名热衷于计算机技术的开发者和学习者，ID 是 <strong>WYHEF</strong>（也就是五氧化二钒的缩写）。</p>
          <p>我热衷于探索代码背后的逻辑，同时也享受构建工具来解决实际问题的过程。目前主要关注后端开发、脚本自动化以及 Web 全栈技术。</p>
        </section>

        <section>
          <h3>关于本站</h3>
          <p>建立这个博客的初衷是为了构建一个属于自己的知识库。在这个信息碎片化的时代，我希望通过长文写作来沉淀思考，记录学习过程中的灵光一现。</p>
          <p>在这里，你主要会看到以下内容：</p>
          <ul class="status-list">
            <li><strong>技术笔记</strong>：Python, Java, SpringBoot 等技术的学习心得与踩坑记录</li>
            <li><strong>项目实战</strong>：个人项目的开发过程复盘与技术总结</li>
            <li><strong>算法与逻辑</strong>：C++ 算法学习过程中的思考</li>
            <li><strong>生活随笔</strong>：旅行、阅读和生活的些许感悟</li>
          </ul>
        </section>

        <section>
          <h3>技术栈</h3>
          <div class="tech-stack">
            {techStack.map(tech => (
              <div class="tech-item">
                <div class="tech-header">
                  <span class="tech-name">{tech.name}</span>
                  <span class="tech-desc">{tech.desc}</span>
                </div>
                <div class="progress-bar">
                  <div
                    class="progress-fill"
                    style={`width: ${tech.percent}%; background: linear-gradient(90deg, ${tech.color}, ${tech.color}dd);`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section>
          <h3>联系我</h3>
          <p>如果你对我的文章感兴趣，或者有技术问题想要交流，欢迎通过社交链接联系我。也可以关注微信公众号 <strong>"五氧化二钒不是废钒"</strong> 获取更多动态。</p>
        </section>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .about-container {
    padding: var(--spacing-xl) 0 var(--spacing-3xl);
  }

  .about-content {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--spacing-xl);
    align-items: start;
  }

  /* Profile 卡片 */
  .profile-card {
    padding: var(--spacing-lg);
    position: sticky;
    top: calc(var(--nav-height) + var(--spacing-lg));
  }

  .avatar-ring {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    padding: 3px;
    background: var(--gradient-accent);
    margin: 0 auto var(--spacing-md);
  }

  .avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid var(--color-bg);
  }

  .profile-info {
    text-align: center;
  }

  .profile-name {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
  }

  .profile-login {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    margin-bottom: var(--spacing-sm);
  }

  .profile-bio {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    border-top: 1px solid var(--color-border);
    padding-top: var(--spacing-md);
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    text-decoration: none;
    border-bottom: none;
    transition: all var(--transition-fast);
    cursor: pointer;
    position: relative;
  }

  .social-link:hover {
    color: var(--color-accent-light);
  }

  /* 微信二维码弹出层 */
  .wechat-trigger:hover .qr-popup {
    display: flex;
    animation: fadeUp 0.2s ease-out;
  }

  .qr-popup {
    display: none;
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border-hover);
    padding: 10px;
    border-radius: var(--radius-md);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    flex-direction: column;
    align-items: center;
    z-index: 100;
    margin-bottom: 10px;
    width: 140px;
  }

  .qr-img {
    width: 120px;
    height: 120px;
    object-fit: contain;
    border-radius: var(--radius-sm);
    margin-bottom: 5px;
  }

  .qr-tip {
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translate(-50%, 10px); }
    to { opacity: 1; transform: translate(-50%, 0); }
  }

  /* Bio 文本区 */
  .bio-text {
    font-size: 1rem;
    line-height: 1.8;
  }

  .bio-text h2 {
    font-size: 1.6rem;
    margin-bottom: var(--spacing-md);
    font-weight: 700;
  }

  .bio-text h3 {
    font-size: 1.25rem;
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    font-weight: 600;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .bio-text p {
    color: var(--color-text-secondary);
    margin-bottom: 1.2em;
  }

  .status-list {
    list-style-type: none;
    margin: 0 0 1.5em 0;
    padding: 0;
  }

  .status-list li {
    margin-bottom: 0.75rem;
    padding-left: 1.2rem;
    position: relative;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .status-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  /* 技能进度条 */
  .tech-stack {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin-top: 1rem;
  }

  .tech-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    margin-bottom: 0.35rem;
  }

  .tech-name {
    font-weight: 600;
    font-family: var(--font-mono);
    color: var(--color-text-primary);
  }

  .tech-desc {
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  .progress-bar {
    width: 100%;
    height: 6px;
    background: var(--color-surface-elevated);
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 1s ease-out;
  }

  @media (max-width: 768px) {
    .about-content {
      grid-template-columns: 1fr;
    }

    .profile-card {
      position: static;
      max-width: 320px;
      margin: 0 auto var(--spacing-lg);
    }
  }
</style>
